.env
# Снимок стека для docker compose monitoring/proxy (БД web или копия main.env)
.slgpu/
__pycache__/
*.pyc
# Node (локальная dev-сборка фронта; lockfile — в git)
web/frontend/node_modules/
.DS_Store
template/*

# Локальные данные на сервере (веса, БД, TSDB). Пресеты data/presets/*.env — только локально (не в git);
# эталонные примеры — examples/presets/*.env
data/**
!data/README.md
!data/**/.gitkeep
!data/presets/
!data/presets/**
data/presets/*.env
!data/bench/
!data/bench/.gitkeep

# Доки агентов, GRACE, Kilo, правила Cursor — только локально, не в репозитории
docs/
grace/
.kilo/
.cursor/