# LiteLLM → vLLM: имя в запросе к прокси — devllm (совпадайте с SLGPU_SERVED_MODEL_NAME / /v1/models).
# В upstream (openai/…) подставляется LITELLM_LLM_ID или SLGPU_SERVED_MODEL_NAME или devllm.

model_list:
  - model_name: devllm
    litellm_params:
      model: openai/__LITELLM_LLM_ID__
      api_base: __LITELLM_VLLM_API_BASE__
      api_key: "EMPTY"
      timeout: 600

litellm_settings:
  set_verbose: false
# master_key: LITELLM_MASTER_KEY в main.env (см. docs.litellm.ai proxy docker)
