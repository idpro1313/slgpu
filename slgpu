#!/usr/bin/env bash
# Единая точка входа slgpu (Linux VM): bootstrap контейнера slgpu-web.
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export SLGPU_ROOT="${ROOT}"

cmd="${1:-help}"
shift || true

case "${cmd}" in
  help|-h|--help)
    exec bash "${ROOT}/scripts/cmd_help.sh" "$@"
    ;;
  web)
    if [[ ! -f "${ROOT}/scripts/cmd_web.sh" ]]; then
      echo "Внутренняя ошибка: нет ${ROOT}/scripts/cmd_web.sh" >&2
      exit 1
    fi
    exec bash "${ROOT}/scripts/cmd_web.sh" "$@"
    ;;
  *)
    echo "Неизвестная команда: ${cmd} (см. ./slgpu help)" >&2
    exec bash "${ROOT}/scripts/cmd_help.sh"
    exit 1
    ;;
esac
