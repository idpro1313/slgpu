# Skeleton environment for slgpu-web. Copy to web/.env and adjust.

# Port and bind for the host port mapping.
WEB_BIND=127.0.0.1
WEB_PORT=8089

# Root log level (uvicorn, app): INFO or DEBUG to see [docker_client][get_by_service] and more.
# WEB_LOG_LEVEL=INFO

# Where SQLite is stored on the host. Bind-mounted into /data inside the container.
WEB_DATA_DIR=./data

# Имена Docker Compose-проектов (лейбл com.docker.compose.project), если у вас не `slgpu` / `slgpu-monitoring`
# (например, COMPOSE_PROJECT_NAME=sigpu → выставьте sigpu / sigpu-monitoring).
# WEB_COMPOSE_PROJECT_INFER=slgpu
# WEB_COMPOSE_PROJECT_MONITORING=slgpu-monitoring

# Defaults that are forwarded to backend probes. They MUST match what the
# slgpu and slgpu-monitoring stacks actually expose on the host.
LLM_API_PORT=8111
LLM_API_PORT_SGLANG=8222
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
LANGFUSE_PORT=3001
LITELLM_PORT=4000
LOKI_PORT=3100
