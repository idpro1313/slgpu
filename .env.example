# Скопируйте в .env и заполните.
# ВАЖНО: не коммитьте продакшен-секреты.
#
# Только настройки сервера и мониторинга. Параметры модели — в configs/models/<preset>.env
# (создаётся вручную или через ./slgpu pull <HF_ID>).
# Движок: configs/vllm/vllm.env и configs/sglang/sglang.env

# -------- Пути --------
# Каталог весов на хосте: ./slgpu pull и compose монтируют его в контейнер как /models.
MODELS_DIR=/opt/models

# -------- Grafana --------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=password
GRAFANA_BIND=0.0.0.0
GRAFANA_PORT=3000
GF_SERVER_ROOT_URL=

# -------- Порт OpenAI API (vLLM / SGLang по очереди) --------
LLM_API_BIND=0.0.0.0

# -------- Prometheus / DCGM / node_exporter --------
PROMETHEUS_BIND=127.0.0.1
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=0
DCGM_BIND=127.0.0.1
NODE_EXPORTER_BIND=127.0.0.1
