# Скопируйте в .env и заполните.
# ВАЖНО: не вставляйте реальные токены в этот файл и не коммитьте .env — только локально в .env.
#
# Этот файл хранит СЕРВЕРНЫЕ настройки (HF-токен, пути, мониторинг).
# Модель-зависимые параметры (MODEL_ID, MAX_MODEL_LEN, KV_CACHE_DTYPE, ...)
# живут в configs/models/<preset>.env и выбираются флагом -m:
#   ./scripts/up.sh vllm -m qwen3-30b-a3b

# -------- Hugging Face --------
# Для чего: доступ к закрытым репозиториям и к rate limits на Hugging Face Hub при скачивании весов.
# Варианты: строка токена с https://huggingface.co/settings/tokens ; пусто = только публичные модели без авторизации.
HF_TOKEN=

# -------- Пути --------
# Для чего: каталог на хосте, куда `download-model.sh` скачивает веса и откуда compose монтирует их в контейнер как `/models`.
# Варианты: любой путь с достаточным местом; типично `/opt/models` на отдельном диске.
MODELS_DIR=/opt/models

# -------- Grafana (веб-интерфейс мониторинга) --------
# Для чего: имя администратора Grafana при первом входе.
# Варианты: любая строка; часто `admin`.
GRAFANA_ADMIN_USER=admin
# Для чего: пароль администратора Grafana.
# Варианты: надёжная строка; на проде снаружи сети обязательно сменить.
GRAFANA_ADMIN_PASSWORD=change_me_in_prod
# Для чего: на каком интерфейсе хоста слушает порт Grafana (безопаснее 127.0.0.1 если доступ только через SSH-туннель).
# Варианты: `0.0.0.0` — все интерфейсы; `127.0.0.1` — только localhost.
GRAFANA_BIND=0.0.0.0
# Для чего: порт HTTP Grafana на хосте (левый в пробросе host:container).
# Варианты: 1–65535, типично `3000`; не должен конфликтовать с другими сервисами.
GRAFANA_PORT=3000
# Для чего: публичный URL Grafana за reverse-proxy (корректные редиректы и ссылки в UI).
# Варианты: пусто = авто; иначе полный URL, например `https://grafana.example.com/`.
GF_SERVER_ROOT_URL=

# -------- Порт OpenAI API (vLLM / SGLang по очереди) --------
# Для чего: на каком адресе хоста открыт порт 8111 с API; сами движки всегда слушают 8111 внутри контейнера.
# Варианты: `0.0.0.0` — со всех интерфейсов; `127.0.0.1` — только с localhost.
LLM_API_BIND=0.0.0.0

# -------- Prometheus / DCGM / node_exporter --------
# Для чего: на каком адресе хоста доступен UI и API Prometheus.
# Варианты: обычно `127.0.0.1` (только локально); `0.0.0.0` — с любого интерфейса (осторожно с firewall).
PROMETHEUS_BIND=127.0.0.1
# Для чего: как долго хранить ряды метрик на диске (рост БД Prometheus).
# Варианты: суффиксы `d`/`w`/`h`/`y`, например `15d`, `30d`, `365d`.
PROMETHEUS_RETENTION_TIME=15d
# Для чего: жёсткий лимит размера TSDB; дополнительно к retention по времени.
# Варианты: `0` = только время; иначе размер в байтах с суффиксами `KB`/`MB`/`GB`/`TB`, например `20GB`.
PROMETHEUS_RETENTION_SIZE=0
# Для чего: bind для метрик NVIDIA DCGM Exporter (GPU).
# Варианты: чаще `127.0.0.1`; `0.0.0.0` если нужен доступ с других машин (не рекомендуется без firewall).
DCGM_BIND=127.0.0.1
# Для чего: bind для node_exporter (CPU/RAM/диск хоста для Grafana dashboard 1860).
# Варианты: обычно `127.0.0.1`.
NODE_EXPORTER_BIND=127.0.0.1

# =====================================================================
# Ниже — fallback для модели, если скрипт вызван без -m (пресеты в configs/models предпочтительнее).
# =====================================================================

# Для чего: идентификатор репозитория на Hugging Face (и путь внутри MODELS_DIR после скачивания).
# Варианты: `org/name`, напр. `Qwen/Qwen3-30B-A3B`; должен совпадать с реально скачанными весами.
MODEL_ID=Qwen/Qwen3-30B-A3B
# Для чего: фиксированный коммит/тег весов для воспроизводимости.
# Варианты: SHA или тег на HF; пусто = ветка по умолчанию (обычно `main`).
MODEL_REVISION=

# Для чего: максимальная длина контекста (подсказка+ответ в токенах) для vLLM `--max-model-len` и SGLang `--context-length`.
# Варианты: число ≤ окна модели; prompt + max_tokens в запросе не должны превышать (иначе ContextOverflowError).
MAX_MODEL_LEN=131072
# Для чего: доля видеопамяти под веса и KV в vLLM (`--gpu-memory-utilization`).
# Варианты: `0.0`–`1.0`; при `VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1` для Qwen часто ~0.9242; при OOM уменьшать (см. пресеты тяжёлых MoE).
GPU_MEM_UTIL=0.9242

# Для чего: число GPU для tensor parallel (шардирование модели по картам).
# Варианты: целое 1…N, N = число выделенных GPU в compose (часто 4 на одном хосте); должно делить конфигурацию модели.
TP=4

# Для чего: лимит токенов в одном scheduler step vLLM при chunked prefill (`--max-num-batched-tokens`).
# Варианты: типично `8192`; больше (12288–24576) — выше пропускная способность при нагрузке, выше риск OOM/TTFT; при проблемах вернуть 8192.
VLLM_MAX_NUM_BATCHED_TOKENS=8192

# Для чего: тип хранения KV-кэша в vLLM и SGLang (`--kv-cache-dtype`).
# Варианты: `fp8_e4m3`, `fp8`, `fp8_e5m2` (у Qwen3 Next/3.6 `fp8_e5m2` может ломать инференс), `auto` (движок выбирает, напр. MXFP4-модели).
KV_CACHE_DTYPE=fp8_e4m3

# Для чего: доля VRAM под статические буферы SGLang (`--mem-fraction-static`); остальное под KV/динамику.
# Варианты: обычно `0.88`–`0.92`; при OOM снижать; при длинном контексте иногда ниже.
SGLANG_MEM_FRACTION_STATIC=0.90

# Для чего: парсер блоков reasoning/thinking в ответе (флаги `--reasoning-parser` в vLLM и SGLang).
# Варианты: `qwen3`, `qwen3-thinking`, `deepseek_r1`, `openai_gptoss`, `glm45`, `minimax_m2`, `kimi_k2` и др. по доке vLLM/SGLang; пусто = отключить, если поддерживается.
REASONING_PARSER=qwen3

# Для чего: парсер вызовов инструментов только в vLLM (`--tool-call-parser`).
# Варианты: `hermes`, `mistral`, `llama3_json`, `kimi_k2`, `minimax_m2`, `glm45`, `pythonic`, `granite`, `openai` (gpt-oss/Harmony) и др.; должен соответствовать семейству модели.
TOOL_CALL_PARSER=hermes

# Для чего: имя поля `model` в запросах бенчмарка; если пусто — берётся первая модель из `/v1/models`.
# Варианты: строка как в API (иногда полный HF id, например `openai/gpt-oss-120b`).
BENCH_MODEL_NAME=
