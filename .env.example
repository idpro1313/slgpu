# Скопируйте в .env и заполните.
# ВАЖНО: не вставляйте реальные токены в этот файл и не коммитьте .env — только локально в .env.
#
# Этот файл хранит СЕРВЕРНЫЕ настройки (HF-токен, пути, мониторинг).
# Модель-зависимые параметры (MODEL_ID, MAX_MODEL_LEN, KV_CACHE_DTYPE, ...)
# живут в configs/models/<preset>.env и выбираются флагом -m:
#   ./scripts/up.sh vllm -m qwen3-30b-a3b
#   MODEL=llama-3.1-70b-instruct ./scripts/up.sh both

# -------- Hugging Face --------
# Создайте токен на https://huggingface.co/settings/tokens
HF_TOKEN=

# -------- Пути --------
# Каталог на хосте (вне контейнера), куда качаются веса
MODELS_DIR=/opt/models

# -------- Grafana (доступ извне) --------
GRAFANA_ADMIN_USER=admin
# ОБЯЗАТЕЛЬНО смените при доступе наружу:
GRAFANA_ADMIN_PASSWORD=change_me_in_prod
# Внешний bind. Для приватного доступа поставьте 127.0.0.1.
GRAFANA_BIND=0.0.0.0
GRAFANA_PORT=3000
# Если за reverse-proxy / по доменному имени, укажите внешний URL, иначе оставьте пустым.
# Пример: GF_SERVER_ROOT_URL=https://grafana.example.com/
GF_SERVER_ROOT_URL=

# -------- Prometheus / DCGM / Node Exporter (приватные порты) --------
PROMETHEUS_BIND=127.0.0.1
DCGM_BIND=127.0.0.1
# node_exporter: метрики ОС для Grafana «Node Exporter Full» (ID 1860). Наружу не открывать.
NODE_EXPORTER_BIND=127.0.0.1

# =====================================================================
# Ниже — fallback-дефолты модели на случай, если -m не указан.
# Нормальный способ — пресеты в configs/models/<name>.env.
# =====================================================================

# Базовая модель (перекрывается пресетом). Обязательна.
MODEL_ID=Qwen/Qwen3-30B-A3B
# Зафиксируйте revision (commit) для воспроизводимости; пусто = main
MODEL_REVISION=

# Контекст и память KV.
# MAX_MODEL_LEN = prompt + max_tokens (иначе 400 ContextOverflowError).
MAX_MODEL_LEN=131072
# 0.9242 — рекомендация vLLM при VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1
# (учёт памяти CUDA Graph, см. configs/vllm/args.env).
GPU_MEM_UTIL=0.9242

# Tensor-parallel size. 4 — один движок на все карты.
# В режиме both up.sh форсит TP=2 и split GPU 0,1 / 2,3 через overlay.
TP=4

# vLLM: лимит токенов в одном scheduler step (--max-num-batched-tokens, chunked prefill).
# 8192 — дефолт. 12288–24576 часто даёт выше RPS при многих параллельных запросах;
# при OOM или росте TTFT на одиночных запросах — верните 8192.
VLLM_MAX_NUM_BATCHED_TOKENS=8192

# Тип KV-кэша (vLLM и SGLang читают одно значение).
# Qwen3 Next / Qwen3.6 (qwen3_next): только fp8 или fp8_e4m3 — fp8_e5m2 даёт RuntimeError.
KV_CACHE_DTYPE=fp8_e4m3

# SGLang: доля VRAM под статические буферы
SGLANG_MEM_FRACTION_STATIC=0.90

# Reasoning / thinking-парсер vLLM
#   qwen3            — Qwen3 / Qwen3-Next / Qwen3.6
#   qwen3-thinking   — варианты с суффиксом -Thinking
#   deepseek_r1      — DeepSeek R1 / дистилляты
#   openai_gptoss    — openai/gpt-oss-*
#   glm45            — GLM-4.5 / 4.6 / 5.x
#   minimax_m2       — MiniMax-M1/M2
#   kimi_k2          — Kimi-K2
#   (пусто)          — без reasoning
REASONING_PARSER=qwen3

# Tool-call-parser vLLM (под модель). Популярные: hermes, mistral, llama3_json,
#   kimi_k2, minimax_m2, glm45, pythonic, granite, openai (gpt-oss / Harmony).
TOOL_CALL_PARSER=hermes

# Имя модели в запросах бенча; пусто — бенч сам возьмёт первую из /v1/models.
BENCH_MODEL_NAME=
