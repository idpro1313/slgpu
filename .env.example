# Скопируйте в .env и заполните.
# ВАЖНО: не коммитьте продакшен-секреты.
#
# Базовые дефолты репозитория — в [main.env](main.env) в корне (загружаются до этого файла).
# Здесь — только сервер, мониторинг, переопределения. Параметры модели — в configs/models/<preset>.env
# (создаётся вручную; ./slgpu pull веса не создаёт пресет).
# Движок: configs/vllm/vllm.env и configs/sglang/sglang.env

# -------- Пути --------

# Для чего: каталог с весами на хосте; монтируется в LLM-контейнер как /models.
# Варианты: абсолютный путь; типично /opt/models или путь внутри $HOME.
MODELS_DIR=/opt/models

# Для чего: тег/дижест образа vLLM (docker-compose, сервис vllm). По умолчанию vllm/vllm-openai:latest.
# GLM-5.1-FP8 (рецепт vllm-project/recipes GLM/GLM5.md): vllm/vllm-openai:glm51 или :glm51-cu130 (CUDA 13+).
#VLLM_DOCKER_IMAGE=vllm/vllm-openai:glm51
# MiniMax-M2.7 (рецепт MiniMax/MiniMax-M2.md): vllm/vllm-openai:minimax27
#VLLM_DOCKER_IMAGE=vllm/vllm-openai:minimax27

# -------- Grafana --------

# Для чего: логин администратора веб-UI Grafana.
# Варианты: произвольная строка; сменить после первого входа при необходимости.
GRAFANA_ADMIN_USER=admin

# Для чего: пароль администратора Grafana.
# Варианты: надёжная строка; не коммитьте реальный пароль в репозиторий.
GRAFANA_ADMIN_PASSWORD=password

# Для чего: адрес, на котором контейнер Grafana слушает HTTP (0.0.0.0 — все интерфейсы).
# Варианты: 0.0.0.0 | 127.0.0.1 (только localhost).
GRAFANA_BIND=0.0.0.0

# Для чего: порт хоста для веб-интерфейса Grafana.
# Варианты: 1–65535, если свободен; по умолчанию 3000.
GRAFANA_PORT=3000

# Для чего: публичный URL Grafana (редиректы, ссылки; опционально).
# Варианты: пусто — авто; или https://grafana.example.com/ для reverse-proxy.
GF_SERVER_ROOT_URL=

# -------- Порт OpenAI API (vLLM / SGLang по очереди) --------

# Для чего: IP, на котором publish’ится порт LLM с хоста.
# Варианты: 0.0.0.0 (все интерфейсы) | 127.0.0.1 (только loopback).
LLM_API_BIND=0.0.0.0
# Для чего: порт на хосте, на который мапится API в docker-compose (см. profiles vllm/sglang).
# Варианты: 8111 (vLLM по умолчанию), 8222 (SGLang в slgpu), любой 1–65535; ./slgpu up -p перекрывает.
#LLM_API_PORT=8111
# Для чего: жёстко задать список физических GPU (например 2,3,4,5) вместо авто 0..TP-1 от ./slgpu up.
#SLGPU_NVIDIA_VISIBLE_DEVICES=0,1,2,3

# -------- Prometheus / DCGM / node_exporter --------

# Для чего: на каком адресе с хоста доступен веб-UI и API Prometheus.
# Варианты: 127.0.0.1 — только с машины; 0.0.0.0 — со всех интерфейсов (осторожно).
PROMETHEUS_BIND=127.0.0.1

# Для чего: как долго хранить сэмплы в TSDB.
# Варианты: например 7d, 15d, 30d, 1y.
PROMETHEUS_RETENTION_TIME=15d

# Для чего: максимальный размер на диске для данных Prometheus; 0 — лимит по размеру отключён.
# Варианты: 0 | например 50GB, 200GB.
PROMETHEUS_RETENTION_SIZE=0

# Для чего: публикация порта DCGM Exporter (метрики GPU).
# Варианты: 127.0.0.1 — только локально; 0.0.0.0 — внешний доступ.
DCGM_BIND=127.0.0.1

# Для чего: публикация порта Node Exporter (метрики хоста: CPU, RAM, диск).
# Варианты: 127.0.0.1 | 0.0.0.0.
NODE_EXPORTER_BIND=127.0.0.1
