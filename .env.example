# Скопируйте в .env и заполните.
# ВАЖНО: не вставляйте реальные токены в этот файл и не коммитьте .env — только локально в .env.

# Hugging Face: создайте токен на https://huggingface.co/settings/tokens и укажите в .env как HF_TOKEN=...
HF_TOKEN=

# Идентификатор модели на HF (для скачивания). Локальный путь в контейнере: /models/${MODEL_ID}
MODEL_ID=Qwen/Qwen3-30B-A3B

# Зафиксируйте revision (commit) для воспроизводимости; пусто = main
MODEL_REVISION=

# Каталог на хосте (вне контейнера), куда качаются веса
MODELS_DIR=/opt/models

# Контекст и память KV.
# MAX_MODEL_LEN = prompt + max_tokens (иначе 400 ContextOverflowError).
# Qwen3 Next: до 262144 (256k). Большое окно резервирует много VRAM под KV; при OOM
# уменьшите окно (131072 / 65536) и/или GPU_MEM_UTIL.
MAX_MODEL_LEN=262144
# 0.9242 — рекомендация самого vLLM при включённом VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1,
# чтобы компенсировать ~0.4% VRAM, уходящих на учёт CUDA Graph памяти (см. configs/vllm/args.env).
GPU_MEM_UTIL=0.9242

# Tensor-parallel size. 4 — один движок на все карты (A/B-режим).
# Для co-run (vLLM + SGLang параллельно, по 2 GPU каждому) используйте TP=2 и overlay
# docker-compose.both.yml (scripts/up.sh both делает это автоматически).
TP=4
# Тип KV-кэша (vLLM и SGLang в compose читают одно значение).
# Qwen3 Next в vLLM (qwen3_next): только fp8 или fp8_e4m3 — fp8_e5m2 даёт RuntimeError/Dynamo assert в attention.
KV_CACHE_DTYPE=fp8_e4m3

# SGLang: доля VRAM под статические буферы (аналог «зарезервировать» под модель/KV)
SGLANG_MEM_FRACTION_STATIC=0.90

# Grafana (доступ извне)
GRAFANA_ADMIN_USER=admin
# ОБЯЗАТЕЛЬНО смените при доступе наружу:
GRAFANA_ADMIN_PASSWORD=change_me_in_prod
# Внешний bind. Для приватного доступа поставьте 127.0.0.1.
GRAFANA_BIND=0.0.0.0
GRAFANA_PORT=3000
# Если за reverse-proxy / по доменному имени, укажите внешний URL, иначе оставьте пустым.
# Пример: GF_SERVER_ROOT_URL=https://grafana.example.com/
GF_SERVER_ROOT_URL=

# Prometheus / DCGM — приватные порты (не для публики). При необходимости поменяйте на 0.0.0.0.
PROMETHEUS_BIND=127.0.0.1
DCGM_BIND=127.0.0.1

# Имя модели в запросах бенча (должно совпадать с served name; по умолчанию = MODEL_ID)
BENCH_MODEL_NAME=

# Reasoning / thinking-режим Qwen3.
# Парсер выделяет блок <think>...</think> в отдельное поле ответа OpenAI API.
# Допустимые значения:
#   qwen3            — для Qwen3 / Qwen3-Next (включает thinking; клиент может выключить per-request)
#   qwen3-thinking   — для моделей с суффиксом -Thinking (всегда мыслят); поддержка только в SGLang
#   deepseek_r1      — DeepSeek R1
# Оставьте qwen3 для Qwen3-30B-A3B / Qwen3-Next.
REASONING_PARSER=qwen3
