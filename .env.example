# Скопируйте в .env и заполните.
# ВАЖНО: не вставляйте реальные токены в этот файл и не коммитьте .env — только локально в .env.

# Hugging Face: создайте токен на https://huggingface.co/settings/tokens и укажите в .env как HF_TOKEN=...
HF_TOKEN=

# Идентификатор модели на HF (для скачивания). Локальный путь в контейнере: /models/${MODEL_ID}
MODEL_ID=Qwen/Qwen3-30B-A3B

# Зафиксируйте revision (commit) для воспроизводимости; пусто = main
MODEL_REVISION=

# Каталог на хосте (вне контейнера), куда качаются веса
MODELS_DIR=/opt/models

# Контекст и память KV
MAX_MODEL_LEN=32768
GPU_MEM_UTIL=0.92
# Тип KV-кэша (vLLM и SGLang в compose читают одно значение).
# Qwen3 Next в vLLM (qwen3_next): только fp8 или fp8_e4m3 — fp8_e5m2 даёт RuntimeError/Dynamo assert в attention.
KV_CACHE_DTYPE=fp8_e4m3

# SGLang: доля VRAM под статические буферы (аналог «зарезервировать» под модель/KV)
SGLANG_MEM_FRACTION_STATIC=0.90

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=password

# Имя модели в запросах бенча (должно совпадать с served name; по умолчанию = MODEL_ID)
BENCH_MODEL_NAME=
