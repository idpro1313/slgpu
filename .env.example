# Скопируйте: cp .env.example .env
# Не коммитьте .env с продакшен-паролями.
#
# Все дефолты (пути, NCCL, Grafana bind/port, Prometheus, vLLM-образ, …) — в [main.env](main.env).
# Здесь — только то, чего в main.env нет, чтобы не дублировать ключи между файлами.
# Порядок загрузки: main.env → .env → configs/<engine>/<engine>.env → configs/models/<preset>.env
#
# Модель: configs/models/<preset>.env. HF-токен: configs/secrets/hf.env. Движок: configs/vllm|sglang/*.env

# -------- Обязательно задать (секрета в main нет) --------

# Пароль администратора Grafana (см. docker-compose, сервис grafana)
GRAFANA_ADMIN_PASSWORD=password

# -------- По желанию (в main отсутствуют) --------

# Публичный URL Grafana (редиректы, ссылки) за reverse-proxy; пусто = авто
#GF_SERVER_ROOT_URL=

# Маска GPU, если не подходит 0..TP-1 (см. README; в main: NVIDIA_VISIBLE_DEVICES)
#SLGPU_NVIDIA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7

# Порт API на хосте, если не 8111 (vLLM) / 8222 (SGLang); иначе ./slgpu up -p
#LLM_API_PORT=8111

# Смена образа vLLM, путей и т.п. — только в main.env (не дублируйте в .env).
