      <purpose>Single-container web control plane: FastAPI + React/Vite, SQLite; стек LLM: native jobs с docker-py (мультислот vLLM/SGLang, таблица engine_slots) + legacy compose для bash ./slgpu; live GPU: nvidia-smi в эфемерном GPU-контейнере; monitoring — native compose; бенч — subprocess scripts; stack_params + cfg.meta; install из main.env.</purpose>
      <path>web/</path>
      <depends>M-CLI, M-PULL, M-UP, M-DOWN, M-MONITOR</depends>
      <verification-ref>V-M-WEB</verification-ref>
      <annotations>
