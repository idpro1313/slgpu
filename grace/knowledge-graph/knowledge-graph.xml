        <fn-services_stack_config PURPOSE="stack_params (param_key, param_value, is_secret) + cfg.meta; миграция JSON cfg.stack/cfg.secrets → строки; sync_merged_flat (приоритет stack_params, public_access.litellm_api_key → LITELLM_MASTER_KEY) + apply_vllm_aliases_to_merged; write_compose_service_env_file → .slgpu/compose-service.env для monitoring/proxy compose; migrate_stack_params_to_canonical_if_needed (UI/API); presentation_stack; write_llm_interp_env; write_langfuse_litellm_env → data/web/secrets/langfuse-litellm.env; init_db: migrate_legacy_json_to_rows, ensure_default_settings, ensure_default_stack_params; ORM app.models.stack_param.StackParam" />
        <fn-services_env_key_aliases PURPOSE="VLLM_STACK_ALIASES: канонические имена (SERVED_MODEL_NAME, MAX_NUM_BATCHED_TOKENS, …) и legacy SLGPU_*; coalesce_str; monitoring_image (GRAFANA_IMAGE + SLGPU_*); normalize preset parameters при импорте" />
        <fn-services_llm_env PURPOSE="merge_llm_stack_env: пресет + stack, SLGPU_NVIDIA_VISIBLE_DEVICES override, apply_vllm_aliases; container_env_for_engine" />
        <fn-api_app_config PURPOSE="GET/POST /app-config/status|install, GET/PATCH /app-config/stack" />
        <fn-api_bench PURPOSE="GET /bench/runs, /runs/{engine}/{ts}/summary; POST scenario|load → native.bench.* jobs" />
        <fn-api_dashboard PURPOSE="GET /dashboard: metrics, runtime (в т.ч. runtime.slots[]), services, host" />
        <fn-api_gpu PURPOSE="GET /gpu/state (nvidia-smi CSV + TTL-кэш), GET /gpu/availability (свободные GPU vs engine_slots, suggested блочно)" />
        <fn-models_engine_slot PURPOSE="app.models.slot.EngineSlot — слот инференса: slot_key, engine, gpu_indices CSV, host_api_port, observed_status" />
        <fn-services_gpu_state PURPOSE="app.services.gpu_state: nvidia-smi через docker-py DeviceRequest(gpu), invalidate_gpu_state_cache при slot up/down" />
        <fn-services_gpu_availability PURPOSE="app.services.gpu_availability: available/busy/suggested по host_info + активным EngineSlot" />
        <fn-services_slot_runtime PURPOSE="app.services.slot_runtime: run_slot_docker, stream docker pull (decode) перед run, контейнер slgpu-{engine} или slgpu-{engine}-{slot_key}, сеть slgpu" />
        <fn-services_host_info PURPOSE="Снимок ОС/CPU/RAM/диска/NVIDIA для дашборда: docker run с bind /proc,/etc хоста (busybox) и nvidia-smi в GPU-контейнере; fallback — локальный /proc и nvidia-smi в namespace web" />
        <fn-services_compose_exec PURPOSE="async docker compose для LLM и monitoring стеков, subprocess logged" />
        <fn-services_native_jobs PURPOSE="handle_native_job: native.slot.up|down|restart (docker-py, мультислот); lock resource slot:{key}; native.model.pull, monitoring, native.proxy.up|down|restart (compose proxy: Langfuse+LiteLLM), bench; периодический flush stdout_tail/message во время RUNNING; stream docker pull перед containers.run. Удалено в 4.0.0: native.llm.*" />
        <fn-job_log PURPOSE="append_job_log: thread-safe строки лога native job; обновление UI по GET /jobs/{id}" />
        <fn-services_slgpu_cli PURPOSE="CliCommand kind=native.* с пустым argv; resource slot:default|slot:{key} (4.0.0: без lock runtime); валидация slot_key/slug/engine/port/tp" />
        <fn-services_jobs PURPOSE="Job runner: native.* → native_jobs; lock по ключу (set discard); task registry; force_engine_slot_halt + POST /runtime/slots/{k}/down?force=1; CancelledError → mark job cancelled" />
        <fn-services_docker_client PURPOSE="get_docker_inspector(): get_by_service — label filter, fallback: нормализованные лейблы, имена Compose v1/v2, жёсткие имена slgpu-* и slgpu-monitoring-*" />
        <fn-services_env_files PURPOSE="Парсер и рендер data/presets/<slug>.env, совместимые с serve.sh" />
        <fn-services_presets PURPOSE="Preset DB ↔ data/presets/*.env: presentation_preset_parameters, migrate_preset_parameters_to_canonical_if_needed; CRUD, POST /presets/{id}/export; POST /presets/sync и /import-templates; GET/PATCH/DELETE как в CONTRACT" />
        <fn-services_hf_models PURPOSE="Реестр HF моделей и статусы скачивания: GET /models синхронизирует DB с фактическими папками MODELS_DIR/&lt;org&gt;/&lt;repo&gt;; в ответе HFModelOut.pull_progress (активная Job native.model.pull по resource=hf_id); active_pull_jobs_by_resource; PATCH меняет revision/notes, DELETE удаляет запись и опционально локальные веса внутри MODELS_DIR" />
        <fn-services_runtime PURPOSE="snapshot: при активных EngineSlot — пробы по каждому слоту (asyncio.gather, RuntimeSlotProbe); иначе compose legacy; tail_slot_logs по slot_key. Удалено в 4.0.0: EngineRun/attach_run_metadata, REST /runtime/up|down|restart|/logs" />
        <fn-api_runtime_slots PURPOSE="GET/POST /runtime/slots, POST /slots/{key}/down|restart, GET slots/{key}/logs; list EngineSlot" />
        <fn-api_docker_logs PURPOSE="GET /docker/containers, …/logs, /docker/engine-events (Engine /events), /docker/daemon-log (journalctl docker); read-only, DockerInspector" />
        <fn-api_presets_clone PURPOSE="POST /presets/{id}/clone (PresetCloneRequest), flush перед ответом" />
        <fn-services_monitoring PURPOSE="Probe: Docker + HTTP; порта и compose project monitoring из слитого стека (БД)" />
        <fn-services_litellm PURPOSE="LiteLLM: GET /v1/models и /health* с `Authorization: Bearer` при наличии `litellm_api_key` в public_access (настройки); порт — слитый стек; public URLs — app_settings + ports_for_probes_sync" />
        <fn-services_app_settings PURPOSE="Persistent UI settings: /api/v1/settings/public-access — `server_host` + опциональный `litellm_api_key` (не отдаётся в GET, только `litellm_api_key_set`)" />
        <fn-core_logging PURPOSE="JSON stdout: один StreamHandler на root; у app/httpx/httpcore/h11/uvicorn*/fastapi/starlette handlers сняты, propagate=True; повторный вызов в startup сбрасывает handler'ы uvicorn" />
        <fn-frontend_app PURPOSE="React SPA (globals.css — компактный макет): Dashboard, Presets, Inference (слоты), Docker, Models, Monitoring, Jobs, Benchmarks, Settings" />
        <export-web-image PURPOSE="slgpu-web:dev, подъём: ./slgpu web up; тома: repo root по тому же абсолютному хост-пути (SLGPU_HOST_REPO=$(pwd) в scripts/cmd_web.sh), ./data/web, ./data/models, docker.sock; entrypoint chown'ит /data и ${WEB_SLGPU_ROOT}/data/{models,presets,bench} под uid 10001 (bench — native.bench.* → data/bench/results); working_dir из compose НЕ задаётся (uvicorn стартует из WORKDIR /srv/app в Dockerfile.web); huggingface_hub[cli] + hf_transfer установлены для slgpu pull, HF_HOME=/data/huggingface и /home/slgpuweb writable; критично для команд из web → docker compose monitoring/llm с корректными bind-маунтами" />
        <export-contract PURPOSE="web/CONTRACT.md — границы CLI/Docker API/SQLite" />
