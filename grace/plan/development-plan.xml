        <export-web-image PURPOSE="Docker image slgpu-web:dev" />
        <export-api-v1 PURPOSE="REST /api/v1: dashboard, models, presets, runtime, monitoring, litellm, jobs, app-config, bench, settings, app-logs/events, **log-reports** (Loki+facts+LiteLLM)" />
