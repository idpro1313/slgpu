# Только для ./slgpu pull (скачивание весов с Hugging Face).
# Скопируйте в configs/secrets/hf.env и задайте токен, если нужны приватные или gated-репозитории:
#   cp configs/secrets/hf.env.example configs/secrets/hf.env
# Файл hf.env в .gitignore.
#
# Запуск vLLM/SGLang с локальной моделью токен не требует — этот файл можно не создавать.

# Варианты: строка с https://huggingface.co/settings/tokens или пусто (публичные репо).
HF_TOKEN=
