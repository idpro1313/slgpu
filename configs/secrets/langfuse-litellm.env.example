# Ключи проекта Langfuse → трейсинг в LiteLLM (прокси).
# Скопируйте и заполните: cp configs/secrets/langfuse-litellm.env.example configs/secrets/langfuse-litellm.env
# Реальный langfuse-litellm.env в .gitignore; без кавычек вокруг значений.
#
# Откуда: Langfuse UI → Project → API keys (Public + Secret).
# ./slgpu monitoring up при отсутствии файла создаёт пустой из этого примера.

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
