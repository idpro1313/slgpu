# Пресет: Qwen3.6-35B-A3B (MoE, VL: hybrid attention+mamba).

# Для чего: репозиторий весов на Hugging Face (путь скачивания и имя сервера в API).
# Варианты: HF id в формате `org/model`; здесь фиксирован семейством Qwen3.6.
MODEL_ID=Qwen/Qwen3.6-35B-A3B
# Для чего: зафиксировать версию весов (воспроизводимость).
# Варианты: commit SHA / тег; пусто — ветка по умолчанию.
MODEL_REVISION=
# Для чего: максимальное окно контекста (токены) для обоих движков.
# Варианты: до заявленного окна модели; 262144 соответствует длинному контексту этой линейки при достаточной VRAM.
MAX_MODEL_LEN=262144
# Для чего: тип KV для Qwen3-Next/Qwen3.6-архитектуры.
# Варианты: `fp8` или `fp8_e4m3`; `fp8_e5m2` для qwen3_next часто даёт RuntimeError — не использовать.
KV_CACHE_DTYPE=fp8_e4m3
# Для чего: доля VRAM под vLLM.
# Варианты: обычно ~0.92–0.93 при профайлере CUDA graph; снижать при OOM.
GPU_MEM_UTIL=0.9242
# Для чего: доля VRAM под статические буферы в SGLang.
# Варианты: типично 0.88–0.92; при OOM снижать.
SGLANG_MEM_FRACTION_STATIC=0.90
# Для чего: chunked prefill в vLLM (--max-num-batched-tokens); переменная SLGPU_* чтобы не было предупреждений Unknown VLLM_* в 0.19+.
SLGPU_MAX_NUM_BATCHED_TOKENS=8192
# Для чего: парсер reasoning для семейства Qwen3.
# Варианты: `qwen3` для нет-thinking; для суффикса -Thinking смотрите `qwen3-thinking` в доке vLLM.
REASONING_PARSER=qwen3
# Для чего: tensor parallel по GPU.
# Варианты: число GPU (должно совпадать с TP в compose / выделенными device_ids). На 4 GPU — поставьте TP=4.
TP=8
