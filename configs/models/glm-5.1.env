# zai-org/GLM-5.1 (bf16). FP8-чекпоинт с меньшим VRAM: пресет glm-5.1-fp8 + рецепт
# https://github.com/vllm-project/recipes/blob/main/GLM/GLM5.md
# Sparse MLA+DSA: fp8 KV в vLLM 0.19 не подходит — только auto (см. README troubleshooting).

# Для чего: Hugging Face id весов (каталог скачивания и имя в API).
MODEL_ID=zai-org/GLM-5.1

# Для чего: зафиксировать ревизию ветки.
MODEL_REVISION=

# Для чего: макс. контекст. 202752 — потолок из config; на 8×~140 GB bf16 MoE при 131072 тоже может OOM в SharedFusedMoE.
# Поднимайте (65536 → 131072 → 202752) после успешного старта и запаса по nvidia-smi.
MAX_MODEL_LEN=65536

# Для чего: тип KV cache в vLLM. Не fp8_e4m3 — иначе No valid attention backend (FLASHMLA_SPARSE + fp8).
KV_CACHE_DTYPE=auto

# Для чего: vLLM --gpu-memory-utilization. Меньше значение — меньше резерв под KV, больше шанс пройти загрузку bf16 MoE (см. сообщение vLLM «lower ... for weights»). При OOM: 0.75 → 0.72 → 0.70.
GPU_MEM_UTIL=0.75

# Для чего: SGLang --mem-fraction-static.
SGLANG_MEM_FRACTION_STATIC=0.90

# Для чего: vLLM chunked prefill (--max-num-batched-tokens); SLGPU_* для vLLM 0.19+.
SLGPU_MAX_NUM_BATCHED_TOKENS=4096

# Для чего: 0 = --no-enable-prefix-caching (vLLM иначе оставит prefix cache включённым по умолчанию).
SLGPU_ENABLE_PREFIX_CACHING=0

# Для чего: tensor parallel.
TP=8

# Для чего: парсер reasoning.
REASONING_PARSER=glm45

# Для чего: парсер tool calls.
TOOL_CALL_PARSER=glm45

BENCH_MODEL_NAME=
