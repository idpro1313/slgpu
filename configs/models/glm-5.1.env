# Пресет: zai-org/GLM-5.1 (семейство GLM-5 / Z.ai, thinking в тегах).

# Для чего: HF-репозиторий модели.
# Варианты: актуальный id организации/имени на Hub для GLM-5.1.
MODEL_ID=zai-org/GLM-5.1
# Для чего: фиксированная ревизия весов.
# Варианты: SHA/тег; пусто — default branch.
MODEL_REVISION=
# Для чего: максимальный контекст.
# Варианты: в пределах заявленной модели и VRAM; 131072 — типичный верхний ориентир.
MAX_MODEL_LEN=131072
# Для чего: тип KV FP8 для vLLM/SGLang.
# Варианты: `fp8_e4m3` / `fp8` для совместимых моделей; см. README при ошибках dtype.
KV_CACHE_DTYPE=fp8_e4m3
# Для чего: доля VRAM vLLM.
# Варианты: 0.90–0.94 типично; снижать при OOM.
GPU_MEM_UTIL=0.9242
# Для чего: mem-fraction-static SGLang.
# Варианты: 0.88–0.92.
SGLANG_MEM_FRACTION_STATIC=0.90
# Для чего: парсер reasoning GLM 4.5/5.x.
# Варианты: `glm45` — согласовано с линейкой Z.ai в vLLM.
REASONING_PARSER=glm45
# Для чего: парсер инструментов vLLM для GLM.
# Варианты: `glm45` — пара к reasoning для этой линейки.
TOOL_CALL_PARSER=glm45
# Для чего: tensor parallel по GPU.
# Варианты: число доступных GPU (напр. 4).
TP=4
