# zai-org/GLM-5.1. Sparse MLA+DSA: fp8 KV в vLLM 0.19 не подходит — только auto (см. README troubleshooting).

# Для чего: Hugging Face id весов (каталог скачивания и имя в API).
MODEL_ID=zai-org/GLM-5.1

# Для чего: зафиксировать ревизию ветки.
MODEL_REVISION=

# Для чего: макс. контекст; по config.json (~200k).
MAX_MODEL_LEN=202752

# Для чего: тип KV cache в vLLM. Не fp8_e4m3 — иначе No valid attention backend (FLASHMLA_SPARSE + fp8).
KV_CACHE_DTYPE=auto

# Для чего: vLLM --gpu-memory-utilization.
GPU_MEM_UTIL=0.92

# Для чего: SGLang --mem-fraction-static.
SGLANG_MEM_FRACTION_STATIC=0.90

# Для чего: vLLM chunked prefill (--max-num-batched-tokens); SLGPU_* для vLLM 0.19+.
SLGPU_MAX_NUM_BATCHED_TOKENS=8192

# Для чего: tensor parallel.
TP=8

# Для чего: парсер reasoning.
REASONING_PARSER=glm45

# Для чего: парсер tool calls.
TOOL_CALL_PARSER=glm45

BENCH_MODEL_NAME=
