# moonshotai/Kimi-K2.6 (MoE; парсеры kimi_k2, как у K2.5)
#
# ВАЖНО (vLLM 0.19, 4×~140 GiB, TP=4): при типичном OOM в create_weights (MoE) на шарде ~137 GiB не хватает
# ещё ~1.3 GiB — это упор в размер весов на GPU, не в KV. Снижение MAX_MODEL_LEN и GPU_MEM_UTIL (вплоть до
# 16384 / 0.72 и профайлер=0) часто НЕ устраняет OOM. Для этой модели на таком железе обычно нужны:
#   • 8×GPU и TP=8 (разнести веса), или
#   • другой/более сжатый чекпоинт на Hugging Face, или
#   • другой движок/сервис, если доступен.
# Пресет оставлен для совместимости парсеров и переменных; не считайте TP=4 на 4×H200 гарантированным.
MODEL_ID=moonshotai/Kimi-K2.6
MODEL_REVISION=
MAX_MODEL_LEN=16384
KV_CACHE_DTYPE=fp8_e4m3
GPU_MEM_UTIL=0.72
# В compose проброшено в environment vLLM (см. docker-compose.yml).
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0
SGLANG_MEM_FRACTION_STATIC=0.92
REASONING_PARSER=kimi_k2
TOOL_CALL_PARSER=kimi_k2
TP=4
