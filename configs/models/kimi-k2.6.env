# Пресет: moonshotai/Kimi-K2.6 (MoE, long context). Подсказки по OOM/графу: configs/sglang/sglang.env

# Для чего: идентификатор весов на Hugging Face.
# Варианты: `org/model`; здесь жёстко moonshotai/Kimi-K2.6.
MODEL_ID=moonshotai/Kimi-K2.6

# Для чего: пин к конкретной ревизии ветки.
# Варианты: SHA, тег, пусто — последние веса по умолчанию.
MODEL_REVISION=

# Для чего: макс. длина контекста (токены) для vLLM/SGLang.
# Варианты: 131072, 262144, …; длинные окна сильно жрут VRAM — снижайте при OOM / нестабильном graph capture.
MAX_MODEL_LEN=262144

# Для чего: dtype KV cache в SGLang.
# Варианты: `fp8_e4m3` (как в пресетах), `auto` (если движок позволяет); см. доку SGLang.
KV_CACHE_DTYPE=fp8_e4m3

# Для чего: теги `<think>` / tool вызовы для линейки Kimi.
# Варианты: `kimi_k2` (см. SGLang/vLLM и configs/models/README.md); другие значения — только по доке движка.
REASONING_PARSER=kimi_k2

# Для чего: формат function/tool в ответах.
# Варианты: `kimi_k2` в пару к REASONING; иначе — парсер может не совпасть с API.
TOOL_CALL_PARSER=kimi_k2

# Для чего: tensor parallel.
# Варианты: 1…N; N = число GPU в compose; 8 — дефолт slgpu H200x8.
TP=8

# Для чего: SGLang `--mem-fraction-static` — меньше пик/граф, при «Capture cuda graph failed» вместе с CUDA_GRAPH_MAX_BS.
# Варианты: 0.70–0.90; 0.78 — компромисс стабильности для Kimi+TP8.
SGLANG_MEM_FRACTION_STATIC=0.78

# Для чего: SGLang `--cuda-graph-max-bs` — макс. batch size при захвате графа.
# Варианты: 8, 16, 32; меньше — стабильнее на MoE+TP8.
SGLANG_CUDA_GRAPH_MAX_BS=16

# Для чего: SGLang `--disable-custom-all-reduce` (NCCL вместо custom AR) при Get_graph_buffer_ipc_meta / custom_all_reduce.cuh.
# Варианты: 0 (default в других пресетах) | 1 (рекомендуется для H200+TP+graph на Kimi, см. лог SGLang).
SGLANG_DISABLE_CUSTOM_ALL_REDUCE=1

# Для чего: vLLM `--gpu-memory-utilization` (для SGLang в serve не читается; поле общее для пресета при смене движка).
# Варианты: 0.85–0.95; снижать при OOM на vLLM.
GPU_MEM_UTIL=0.90

# Для чего: убрать --enable-torch-compile при сбоях на graph/compile.
# Варианты: раскомментировать SGLANG_ENABLE_TORCH_COMPILE=0, если SGLang снова падает на capture.
# SGLANG_ENABLE_TORCH_COMPILE=0

# Для чего: крайняя мера — отключить CUDA graph целиком.
# Варианты: SGLANG_DISABLE_CUDA_GRAPH=1; сильно снижает RPS, см. sglang.env.
# SGLANG_DISABLE_CUDA_GRAPH=1
