# Пресет: moonshotai/Kimi-K2.6 (MoE). На 4×~140 GiB TP=4 часто не помещается — читайте комментарии в README.
#
# ВАЖНО: OOM в create_weights при типичных OOM на шарде — упор в размер весов; снижение MAX_MODEL_LEN/GPU_MEM_UTIL часто не помогает.
# Варианты решения: 8×GPU TP=8, другой чекпоинт, или другой сервис.

# Для чего: HF id модели.
# Варианты: `moonshotai/Kimi-K2.6` при использовании этого пресета.
MODEL_ID=moonshotai/Kimi-K2.6
# Для чего: зафиксировать ревизию весов.
# Варианты: SHA/тег; пусто — по умолчанию.
MODEL_REVISION=
# Для чего: контекст; здесь занижен для экономии VRAM (не всегда снимает OOM при загрузке весов).
# Варианты: увеличивать только если веса успешно грузятся и есть запас памяти.
MAX_MODEL_LEN=16384
# Для чего: тип KV FP8.
# Варианты: `fp8_e4m3` как безопасный выбор для Kimi на vLLM/SGLang.
KV_CACHE_DTYPE=fp8_e4m3
# Для чего: доля VRAM vLLM; занижена относительно Qwen из‑за тяжёлых MoE.
# Варианты: 0.70–0.92; при OOM на загрузке весов снижение может не помочь (см. шапку пресета).
GPU_MEM_UTIL=0.72
# Для чего: отключить учёт CUDA graphs в профайлере памяти vLLM (меньше «оптимистичного» util).
# Варианты: `0` или `1`; для этого пресета `0` чтобы не завышать память под графы.
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0
# Для чего: mem-fraction-static SGLang.
# Варианты: при нехватке памяти снижать; здесь чуть выше для баланса с низким контекстом.
SGLANG_MEM_FRACTION_STATIC=0.92
# Для чего: парсер reasoning Kimi K2.
# Варианты: `kimi_k2` для K2.x в vLLM.
REASONING_PARSER=kimi_k2
# Для чего: парсер инструментов vLLM.
# Варианты: `kimi_k2` для того же семейства.
TOOL_CALL_PARSER=kimi_k2
# Для чего: tensor parallel (4 GPU в типичном compose).
# Варианты: если есть 8 GPU — пробовать TP=8 для этой модели.
TP=4
