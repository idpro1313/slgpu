# moonshotai/Kimi-K2.6 (MoE; парсеры kimi_k2, как у K2.5)
# На 4×~140 GiB при MAX_MODEL_LEN=131072 и GPU_MEM_UTIL=0.93 у vLLM 0.19 часто CUDA OOM
# при создании весов MoE (нужно ещё ~1 GiB сверх уже занятых ~137 GiB). Ниже — более щадящие дефолты;
# после успешного старта можно поднять MAX_MODEL_LEN по шагам и смотреть на OOM.
# Альтернатива: больше GPU (TP=8), другой чекпоинт на HF, PYTORCH_ALLOC_CONF в configs/vllm/args.env.
MODEL_ID=moonshotai/Kimi-K2.6
MODEL_REVISION=
MAX_MODEL_LEN=65536
KV_CACHE_DTYPE=fp8_e4m3
GPU_MEM_UTIL=0.88
SGLANG_MEM_FRACTION_STATIC=0.92
REASONING_PARSER=kimi_k2
TOOL_CALL_PARSER=kimi_k2
TP=4
