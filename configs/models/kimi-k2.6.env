# moonshotai/Kimi-K2.6 (MoE; парсеры kimi_k2, как у K2.5)
# На 4×~140 GiB TP=4: веса шарда ~137 GiB; не хватает ~1.3 GiB на последний буфер MoE (OOM в create_weights).
# Снижение MAX_MODEL_LEN с 131k→65k почти не помогает — упираемся в размер весов на GPU, не в KV.
# Действия: ниже GPU_MEM_UTIL (меньше резерва под KV → больше для весов при инициализации), меньше контекст,
# отключить профайлер CUDA graph. Если всё ещё OOM — нужны 8×GPU (TP=8) или другой чекпоинт на HF.
MODEL_ID=moonshotai/Kimi-K2.6
MODEL_REVISION=
MAX_MODEL_LEN=16384
KV_CACHE_DTYPE=fp8_e4m3
GPU_MEM_UTIL=0.72
# В compose проброшено в environment vLLM (см. docker-compose.yml).
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0
SGLANG_MEM_FRACTION_STATIC=0.92
REASONING_PARSER=kimi_k2
TOOL_CALL_PARSER=kimi_k2
TP=4
