# moonshotai/Kimi-K2.6 (MoE; парсеры kimi_k2, как у K2.5)
# При старте смотрите полный лог воркера: `WorkerProc initialization failed` — сама по себе
# обёртка; выше по логу ищите CUDA OOM, ImportError и т.д.
# Если падает без явного OOM — попробуйте в configs/vllm/args.env: VLLM_USE_V1=0 (старый движок).
# Если OOM — уменьшите MAX_MODEL_LEN / GPU_MEM_UTIL или используйте FP8-чекпоинт на HF, если есть.
MODEL_ID=moonshotai/Kimi-K2.6
MODEL_REVISION=
MAX_MODEL_LEN=131072
KV_CACHE_DTYPE=fp8_e4m3
GPU_MEM_UTIL=0.93
SGLANG_MEM_FRACTION_STATIC=0.92
REASONING_PARSER=kimi_k2
TOOL_CALL_PARSER=kimi_k2
TP=4
