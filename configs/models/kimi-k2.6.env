# Пресет: moonshotai/Kimi-K2.6 (MoE, long context). SGLang: см. sglang.env — обход OOM/«Capture cuda graph failed».

# Для чего: веса на Hugging Face.
MODEL_ID=moonshotai/Kimi-K2.6
MODEL_REVISION=
# Для чего: длинный контекст; при OOM / нестабильном графе снижайте (например 131072).
MAX_MODEL_LEN=262144
KV_CACHE_DTYPE=fp8_e4m3
# Для чего: парсер reasoning/tool для линейки Kimi (см. configs/models/README.md).
REASONING_PARSER=kimi_k2
TOOL_CALL_PARSER=kimi_k2
# Для чего: tensor parallel.
TP=8
# Снижение «Capture cuda graph failed» (H200/TP8, custom all-reduce) — вместе с настройками ниже.
SGLANG_MEM_FRACTION_STATIC=0.78
SGLANG_CUDA_GRAPH_MAX_BS=16
# Если после загрузки снова падает на graph capture: 0
# SGLANG_ENABLE_TORCH_COMPILE=0
# Крайняя мера: SGLANG_DISABLE_CUDA_GRAPH=1
GPU_MEM_UTIL=0.90
