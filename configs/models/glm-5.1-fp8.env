# zai-org/GLM-5.1-FP8 — рекомендация vLLM для 8×H200: [GLM/GLM5.md](https://github.com/vllm-project/recipes/blob/main/GLM/GLM5.md)
# Скорость: MTP + большой max-num-batched-tokens. OOM: снизить SLGPU_MAX_NUM_BATCHED_TOKENS (16384→12288) или убрать SLGPU_VLLM_SPECULATIVE_CONFIG.

# Что: HF id FP8-чекпоинта.
# Для чего: pull и served-model-name по умолчанию.
# Варианты: zai-org/GLM-5.1-FP8.
MODEL_ID=zai-org/GLM-5.1-FP8

# Что: Docker-образ vLLM glm51, cu130, x86_64.
# Для чего: DeepGEMM/FP8 путь из рецепта; не latest.
# Варианты: glm51-x86_64-cu130 или glm51-cu130 (multi-arch).
VLLM_DOCKER_IMAGE=vllm/vllm-openai:glm51-x86_64-cu130

# Что: ревизия HF.
# Для чего: фиксация весов.
# Варианты: SHA, тег; пусто.
MODEL_REVISION=

# Что: JSON для vLLM --speculative-config (MTP, multi-token prediction).
# Для чего: ускорение decode по [GLM/GLM5.md] «8×H200»; ``method``/``num_speculative_tokens`` как в рецепте.
# Варианты: отключить строку при нестабильности; ``num_speculative_tokens`` 1–3.
SLGPU_VLLM_SPECULATIVE_CONFIG='{"method":"mtp","num_speculative_tokens":3}'

# Что: --max-model-len; ниже потолка 202752 из config, старт безопасный по VRAM.
# Для чего: после приёмки по nvidia-smi можно поднять к полному 202k.
# Варианты: 200704, 202752, ниже — если OOM.
MAX_MODEL_LEN=200704

# Что: --kv-cache-dtype; sparse MLA — только auto.
# Для чего: совместимость attention backend.
# Варианты: auto; не называть fp8 KV для этой спарс-конфигурации в 0.19.
KV_CACHE_DTYPE=auto

# Что: --gpu-memory-utilization.
# Для чего: плотнее пул при FP8+8×GPU; оставляем запас для длинных сессий.
# Варианты: 0.90–0.95; 0.92 при OOM в длинных сессиях.
GPU_MEM_UTIL=0.94

# Что: SGLang mem-fraction-static.
# Для чего: единообразие при смене движка.
# Варианты: 0.88–0.92.
SGLANG_MEM_FRACTION_STATIC=0.90

# Что: vLLM --max-num-batched-tokens.
# Для чего: throughput (chunked prefill); выше — больше VRAM.
# Варианты: 12288, 16384, 8192 при OOM.
SLGPU_MAX_NUM_BATCHED_TOKENS=16384

# Что: prefix caching (0 → --no-enable-prefix-caching).
# Для чего: рекомендация GLM-репо для бенчей/стабильности sparse.
# Варианты: 0 (здесь) | 1 — проверять совместимость.
SLGPU_ENABLE_PREFIX_CACHING=0

# Что: --tensor-parallel-size.
# Для чего: 8×GPU в slgpu-шаблоне.
# Варианты: 8 и меньше по числу карт.
TP=8

# Что: --reasoning-parser.
# Для чего: GLM-5.1 / GLM-5.1-FP8.
# Варианты: glm45.
REASONING_PARSER=glm45

# Что: --tool-call-parser.
# Для чего: FP8 ветка в рецепте использует glm47.
# Варианты: glm47; bf16 в другом пресете — glm45.
TOOL_CALL_PARSER=glm47

# Что: --chat-template-content-format.
# Для чего: GLM5.md требует string для этой линейки.
# Варианты: string (здесь); иначе по доке vLLM/GLM.
CHAT_TEMPLATE_CONTENT_FORMAT=string

# Что: имя model для сценариев bench, если не авто.
# Для чего: явный alias в бенчах.
# Варианты: пусто или строка.
BENCH_MODEL_NAME=
