# zai-org/GLM-5.1-FP8 — рекомендованный вариант vLLM для 8×H200/подобное (см. GLM/GLM5.md):
# https://github.com/vllm-project/recipes/blob/main/GLM/GLM5.md
# Образ: в .env задайте VLLM_DOCKER_IMAGE=vllm/vllm-openai:glm51 (при CUDA 13+: :glm51-cu130).

MODEL_ID=zai-org/GLM-5.1-FP8
MODEL_REVISION=

# Ниже полного 202k старта; приёмка по nvidia-smi — поднять как у bf16.
#MAX_MODEL_LEN=131072

KV_CACHE_DTYPE=auto
GPU_MEM_UTIL=0.88
SGLANG_MEM_FRACTION_STATIC=0.90
SLGPU_MAX_NUM_BATCHED_TOKENS=8192
SLGPU_ENABLE_PREFIX_CACHING=0
TP=8
REASONING_PARSER=glm45
TOOL_CALL_PARSER=glm47
CHAT_TEMPLATE_CONTENT_FORMAT=string
BENCH_MODEL_NAME=
