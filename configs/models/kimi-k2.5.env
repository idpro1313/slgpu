# moonshotai/Kimi-K2.5 (MoE, thinking через <think>, специализированные tool-tokens)
# ВНИМАНИЕ: семейство Kimi-K2 — ~1T параметров; на 4×H200 помещается только в FP8.
# Если MODEL_ID не-FP8 вариант — поменяйте на квантованный (например, с суффиксом -FP8)
# либо увеличьте SGLANG_MEM_FRACTION_STATIC / уменьшите MAX_MODEL_LEN при OOM.
MODEL_ID=moonshotai/Kimi-K2.5
MODEL_REVISION=
MAX_MODEL_LEN=131072
KV_CACHE_DTYPE=fp8_e4m3
GPU_MEM_UTIL=0.93
SGLANG_MEM_FRACTION_STATIC=0.92
REASONING_PARSER=kimi_k2
TOOL_CALL_PARSER=kimi_k2
TP=4
