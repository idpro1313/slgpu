# deepseek-ai/DeepSeek-V4-Pro — MoE (1.6T / ~49B act, 384 experts routed), FP8; https://huggingface.co/deepseek-ai/DeepSeek-V4-Pro
# Тяжелее Flash: чаще OOM, EP/снижение MAX_MODEL_LEN. Поддержка v4: https://vllm.ai/blog/deepseek-v4
#
# Что: HF id.
# Для чего: pull, API.
# Варианты: deepseek-ai/DeepSeek-V4-Pro.
MODEL_ID=deepseek-ai/DeepSeek-V4-Pro

# Что: Docker-образ vLLM deepseekv4, cu130, x86_64.
# Для чего: та же линия, что и Flash.
# Варианты: deepseekv4-x86_64-cu130, deepseekv4-cu130.
VLLM_DOCKER_IMAGE=vllm/vllm-openai:deepseekv4-x86_64-cu130

# Что: пин весов.
# Для чего: воспроизводимость.
# Варианты: SHA, тег, пусто.
MODEL_REVISION=

# Что: --max-model-len. Рецепт [vLLM DeepSeek-V4-Pro](https://recipes.vllm.ai/deepseek-ai/DeepSeek-V4-Pro):
# Think Max в чат-шаблоне без обрезки — при необходимости >= 393216; здесь 256K для баланса KV/конкуренции.
# Варианты: 196608, 262144, 393216, …; ниже — больше слотов для параллельных запросов.
MAX_MODEL_LEN=262144

# Что: vLLM --max-num-seqs (сколько последовательностей планировщик обрабатывает за итерацию; верх — по OOM).
# Для чего: явный лимит «не больше N параллельных»; типично 64–256, подбирать после снижения MAX_MODEL_LEN.
# Варианты: пусто (дефолт vLLM) | 64 | 128 | …
SLGPU_VLLM_MAX_NUM_SEQS=128

# Что: --kv-cache-dtype. Для DeepseekV4 vLLM требует строку, начинающуюся с fp8 (assert при auto).
# Для чего: Pro MoE, KV; vLLM выбирает конкретный fp8-режим внутри семейства.
# Варианты: fp8 (здесь) | fp8_e4m3 | fp8_e5m2; не auto — иначе «only supports fp8 kv-cache… got auto».
KV_CACHE_DTYPE=fp8

# Что: vLLM --attention-backend; не задано — путь движка (в логе: fp8_ds_mla KV).
# Для чего: если нужен «стандартный» fp8 KV-cache по подсказке vLLM — раскомментируйте FLASHINFER_MLA_SPARSE и проверьте на стенде.
# Варианты: пусто | FLASHINFER_MLA_SPARSE (см. INFO: deepseek_v4_attention.py)
#SLGPU_VLLM_ATTENTION_BACKEND=FLASHINFER_MLA_SPARSE

# Что: --gpu-memory-utilization. vLLM V1 требует KV на одну «полную» последовательность max_model_len.
# Для чего: при MAX_MODEL_LEN=262144 + веса MoE + FP8 кэш + CUDA graphs: 0.88 даёт слишком мало free KV
# (ошибка: нужно ~8.3 GiB, доступно ~6.7). При VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1 vLLM пишет,
# что 0.88 ≈ 0.857 «без учёта графов»; 0.91 на практике всё ещё давал ~6.7 GiB free KV при 262K
# (нужно ~8.3). Ориентир 0.93–0.94; снижать MAX_MODEL_LEN или VLLM_MEMORY_PROFILER=0 при OOM.
# Варианты: 0.90–0.95; смотрите vLLM-лог: Available KV cache / estimated maximum model length.
GPU_MEM_UTIL=0.94

# Что: SGLang --mem-fraction-static.
# Для чего: SGLang-ветка; держим близко к GPU_MEM_UTIL при переключении движка.
# Варианты: 0.85–0.92.
SGLANG_MEM_FRACTION_STATIC=0.94

# Что: vLLM --max-num-batched-tokens.
# Для чего: prefill/throughput при 256K окне; при OOM понижать.
# Варианты: 8192, 12288, 16384
SLGPU_MAX_NUM_BATCHED_TOKENS=12288

# Что: --tensor-parallel-size.
# Для чего: 8 карт.
# Варианты: 8, при меньшем числе GPU — пропорционально.
TP=8

# Что: --reasoning-parser.
# Для чего: vLLM рекомендует deepseek_v4 для V4 (не deepseek_r1 — R1-стиль); см. https://vllm.ai/blog/deepseek-v4
# Варианты: deepseek_v4 | deepseek_r1 (только R1-семейство).
REASONING_PARSER=deepseek_v4

# Что: --tool-call-parser.
# Для чего: тот же формат, что и reasoning у V4; см. блог vLLM.
# Варианты: deepseek_v4; список в образе: ToolParserManager.tool_parsers
TOOL_CALL_PARSER=deepseek_v4

# Что: vLLM --tokenizer-mode.
# Для чего: рецепт V4; без этого возможны сбои разбора/«пустой» ответ vs ожидаемое.
# Варианты: deepseek_v4 | пусто (не передавать)
SLGPU_VLLM_TOKENIZER_MODE=deepseek_v4

# Что: vLLM memory profiler при старте.
# Для чего: 1 — точнее учёт CUDA graph / KV (рекомендация vLLM 0.19+); дольше старт.
# Варианты: 0 | 1
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1

# Что: --enable-expert-parallel. Рецепт H200 в vLLM: DP+EP и `--data-parallel-size 8` — **другая** топология, не наш TP8.
# Для чего: 0 = текущий slgpu-шаблон 8×GPU TP8; 1 — только если проверяете рецепт EP отдельно.
# Варианты: 0 (здесь) | 1
SLGPU_ENABLE_EXPERT_PARALLEL=0

# Что: vLLM --block-size; [блог V4](https://vllm.ai/blog/deepseek-v4) / лог: DEEPSEEK_SPARSE_SWA 256.
SLGPU_VLLM_BLOCK_SIZE=256

# Что: vLLM --compilation-config; ориентир [блог V4](https://vllm.ai/blog/deepseek-v4) (cudagraph + custom_ops).
# При ошибке разбора JSON в образе — уберите или упростите.
SLGPU_VLLM_COMPILATION_CONFIG='{"cudagraph_mode":"FULL_AND_PIECEWISE","custom_ops":["all"]}'

# Что: имя model для бенчей.
# Для чего: непусто — явный alias; пусто — авто.
# Варианты: строка или пусто.
BENCH_MODEL_NAME=
