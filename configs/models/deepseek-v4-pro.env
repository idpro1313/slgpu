# deepseek-ai/DeepSeek-V4-Pro — MoE (1.6T total / ~49B activated, 384 routed experts), FP8 веса; карточка HF:
# https://huggingface.co/deepseek-ai/DeepSeek-V4-Pro
# В config.json: max_position_embeddings=1048576 (1M), model_type=deepseek_v4; чат без Jinja — папка encoding
# в репозитории. Тяжелее Flash (13B act): чаще нужен expert parallel / снижение MAX_MODEL_LEN при OOM.
# Поддержка vLLM: https://vllm.ai/blog/deepseek-v4 — свежий образ (main.env: VLLM_DOCKER_IMAGE).

MODEL_ID=deepseek-ai/DeepSeek-V4-Pro
MODEL_REVISION=

# 384K — ориентир для Think Max (карточка: окно ≥384K); полный 1M в config — при достаточном VRAM, иначе снижайте.
MAX_MODEL_LEN=393216
KV_CACHE_DTYPE=auto
GPU_MEM_UTIL=0.88
SGLANG_MEM_FRACTION_STATIC=0.88
SLGPU_MAX_NUM_BATCHED_TOKENS=8192
TP=8
REASONING_PARSER=deepseek_r1
TOOL_CALL_PARSER=pythonic

# KV: auto — vLLM подбирает dtype. Pro — крупный MoE: при OOM снижайте MAX_MODEL_LEN, GPU_MEM_UTIL, batched tokens;
# по рецепту vLLM рассмотрите SLGPU_ENABLE_EXPERT_PARALLEL=1 (и согласуйте с TP/GPU).
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0
SLGPU_ENABLE_EXPERT_PARALLEL=0

BENCH_MODEL_NAME=
