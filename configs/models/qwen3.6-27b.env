# Пресет: Qwen/Qwen3.6-27B (dense+hybrid attention+mamba, VL). Throughput на 8× H200: см. SLGPU_MAX_NUM_BATCHED_TOKENS, GPU_MEM_UTIL.

# Для чего: репозиторий весов на Hugging Face (путь скачивания и имя в API).
# Варианты: HF id `org/model`; здесь Qwen3.6-27B.
MODEL_ID=Qwen/Qwen3.6-27B

# Для чего: зафиксировать версию весов (воспроизводимость).
# Варианты: commit SHA / тег; пусто — ветка по умолчанию.
MODEL_REVISION=

# Для чего: максимальное окно контекста (токены) для vLLM и SGLang.
# Варианты: до заявленного в карточке; 262144 — длинный контекст линейки при достаточной VRAM.
MAX_MODEL_LEN=262144

# Для чего: тип KV для Qwen3-Next/Qwen3.6-архитектуры.
# Варианты: `fp8` или `fp8_e4m3`; `fp8_e5m2` для qwen3_next часто даёт RuntimeError — не использовать.
KV_CACHE_DTYPE=fp8_e4m3

# Для чего: доля VRAM под vLLM. 0.9262 — рекомендация vLLM 0.19 с VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1 (сохранение эффективного KV).
# Варианты: ~0.92–0.93; снижать при OOM.
GPU_MEM_UTIL=0.9262

# Для чего: доля VRAM под статические буферы SGLang.
# Варианты: 0.88–0.92; снижать при OOM или при Capture cuda graph failed.
SGLANG_MEM_FRACTION_STATIC=0.90

# Для чего: chunked prefill vLLM (`--max-num-batched-tokens`); префикс SLGPU_* — без лишних VLLM_* в 0.19+.
# Варианты: 4096, 8192, 16384, 32768; throughput — 16384 на H200 при long context.
SLGPU_MAX_NUM_BATCHED_TOKENS=16384

# Для чего: парсер reasoning для Qwen3.
# Варианты: `qwen3` (обычно); для -Thinking смотрите `qwen3-thinking` в доке vLLM.
REASONING_PARSER=qwen3

# Для чего: парсер tool calls (vLLM).
TOOL_CALL_PARSER=hermes

# Для чего: tensor parallel по GPU.
# Варианты: 1…N; N = TP из ./slgpu up; на 4 GPU — TP=4.
TP=8
