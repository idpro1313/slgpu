# Пресет: openai/gpt-oss-120b (MoE, native MXFP4, Harmony). Нужен актуальный vLLM.

# Для чего: репозиторий весов на HF.
# Варианты: для gpt-oss — `openai/gpt-oss-120b` (имя в запросах должно совпадать с served-model-name).
MODEL_ID=openai/gpt-oss-120b
# Для чего: фиксация ревизии весов.
# Варианты: SHA/тег; пусто — по умолчанию на HF.
MODEL_REVISION=
# Для чего: окно контекста в токенах.
# Варианты: по допустимому для модели и VRAM; 131072 — рабочий ориентир при достаточной памяти.
MAX_MODEL_LEN=131072
# Для чего: формат KV при MXFP4 весах.
# Варианты: `auto` — движок выбирает совместимый тип; при проблемах см. доку fp8/bfloat16 для вашей версии vLLM.
KV_CACHE_DTYPE=auto
# Для чего: `--gpu-memory-utilization` vLLM при включённом профайлере CUDA graphs.
# Варианты: ~0.9296 по рекомендациям vLLM 0.19 для gpt-oss; при советах в логе можно чуть поднять; при OOM снизить.
GPU_MEM_UTIL=0.9296
# Для чего: chunked prefill / батч prefill в vLLM (пропускная способность).
# Варианты: `8192` по умолчанию в compose; здесь `16384` — агрессивнее, может потребовать больше VRAM.
VLLM_MAX_NUM_BATCHED_TOKENS=16384
# Для чего: статическая доля VRAM в SGLang.
# Варианты: обычно 0.88–0.92.
SGLANG_MEM_FRACTION_STATIC=0.90
# Для чего: парсер reasoning для OpenAI Harmony (gpt-oss).
# Варианты: для этой модели — `openai_gptoss` (см. таблицу в configs/models/README.md).
REASONING_PARSER=openai_gptoss
# Для чего: парсер tool calls в vLLM; для Harmony нельзя `hermes`.
# Варианты: **`openai`** для gpt-oss; иначе ошибки вида Hermes2ProToolParser/token_ids.
TOOL_CALL_PARSER=openai
# Для чего: поле `model` в бенчмарке и клиентах (должно совпадать с `/v1/models`).
# Варианты: полный id как в API — здесь `openai/gpt-oss-120b`.
BENCH_MODEL_NAME=openai/gpt-oss-120b
# Для чего: tensor parallel.
# Варианты: обычно равно числу GPU в compose (4).
TP=4
