# openai/gpt-oss-120b (MoE ~117B total / ~5.1B active, native MXFP4)
# Harmony-формат; reasoning и tools идут через OpenAI Harmony канал.
# Требуется свежий vLLM (>= 0.10.1 для gpt-oss), образ vllm/vllm-openai:latest.
MODEL_ID=openai/gpt-oss-120b
MODEL_REVISION=
MAX_MODEL_LEN=131072
# Веса уже MXFP4; не форсим fp8 KV — пусть движок выберет сам.
KV_CACHE_DTYPE=auto
GPU_MEM_UTIL=0.9242
SGLANG_MEM_FRACTION_STATIC=0.90
REASONING_PARSER=openai_gptoss
# gpt-oss использует harmony; специализированного tool-parser’а нет — hermes безопасен.
TOOL_CALL_PARSER=hermes
TP=4
