# openai/gpt-oss-120b (MoE ~117B total / ~5.1B active, native MXFP4)
# Harmony-формат; reasoning и tools идут через OpenAI Harmony канал.
# Требуется свежий vLLM (>= 0.10.1 для gpt-oss), образ vllm/vllm-openai:latest.
MODEL_ID=openai/gpt-oss-120b
MODEL_REVISION=
MAX_MODEL_LEN=131072
# Веса уже MXFP4; не форсим fp8 KV — пусть движок выберет сам.
KV_CACHE_DTYPE=auto
# При VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1 vLLM 0.19 рекомендует ~0.9296
# для того же эффективного KV, что 0.9242 без профайлера (см. лог gpu_worker).
GPU_MEM_UTIL=0.9296
SGLANG_MEM_FRACTION_STATIC=0.90
REASONING_PARSER=openai_gptoss
# Обязательно openai (Harmony), не hermes — иначе TypeError: Hermes2ProToolParser... token_ids
TOOL_CALL_PARSER=openai
# Имя в OpenAI API = полный HF id (как --served-model-name)
BENCH_MODEL_NAME=openai/gpt-oss-120b
TP=4
