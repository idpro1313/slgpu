# MiniMaxAI/MiniMax-M2.7 — рецепт vLLM: https://github.com/vllm-project/recipes/blob/main/MiniMax/MiniMax-M2.md
# Образ: в .env задайте VLLM_DOCKER_IMAGE=vllm/vllm-openai:minimax27
# Важно: «голый» TP8 не поддерживается; на NVIDIA — базово TP4. На 8×GPU vLLM даёт TP4+EP
# (tensor 4 + expert parallel). Маску GPU см. ниже: иначе ./slgpu up отдаст в контейнер только 0..TP-1.

MODEL_ID=MiniMaxAI/MiniMax-M2.7
MODEL_REVISION=

# 196K tokens на последовательность (рецепт); 196*1024
MAX_MODEL_LEN=200704
KV_CACHE_DTYPE=fp8_e4m3
GPU_MEM_UTIL=0.95
SGLANG_MEM_FRACTION_STATIC=0.92
SLGPU_MAX_NUM_BATCHED_TOKENS=24576
TP=4
REASONING_PARSER=minimax_m2
TOOL_CALL_PARSER=minimax_m2

# fusion из PR 37045 — нужен vLLM с fuse_minimax_qk_norm
SLGPU_VLLM_COMPILATION_CONFIG='{"mode":3,"pass_config":{"fuse_minimax_qk_norm":true}}'

# 8×H200/подобное: expert parallel; на 4×GPU поставьте 0
SLGPU_ENABLE_EXPERT_PARALLEL=1

# Раскомментируйте для сценария DP8+EP из рецепта (и согласуйте TP/EP с докой vLLM)
# SLGPU_VLLM_DATA_PARALLEL_SIZE=8

# 8 карт: иначе при TP=4 будут видны только GPU 0–3. На ровно 4×GPU удалите строку
# (останется 0,1,2,3) или оставьте SLGPU_NVIDIA_VISIBLE_DEVICES=0,1,2,3
SLGPU_NVIDIA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7

BENCH_MODEL_NAME=
