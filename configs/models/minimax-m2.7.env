# MiniMaxAI/MiniMax-M2.7 — рецепт vLLM: [MiniMax-M2.md](https://github.com/vllm-project/recipes/blob/main/MiniMax/MiniMax-M2.md)
# «Чистый» TP8 не поддерживается: базовый TP4; на 8×GPU — TP4+EP. Маска GPU: все 0–7, иначе compose выдаст только 0..TP-1.
#
# Что: Docker-образ vLLM minimax27, cu130, x86_64.
# Для чего: оптимизации MiniMax M2 (fusion и т.д. в линейке образа).
# Варианты: [Hub vllm/vllm-openai](https://hub.docker.com/r/vllm/vllm-openai/tags) minimax27-*.
VLLM_DOCKER_IMAGE=vllm/vllm-openai:minimax27-x86_64-cu130

# Что: HF id.
# Для чего: pull, имя в /v1/models.
# Варианты: MiniMaxAI/MiniMax-M2.7.
MODEL_ID=MiniMaxAI/MiniMax-M2.7

# Что: ревизия HF.
# Для чего: фиксация весов.
# Варианты: SHA, тег, пусто.
MODEL_REVISION=

# Что: --max-model-len; 196*1024 по рецепту длинного контекста.
# Для чего: соответствие сценарию 196K tokens/seq в доке.
# Варианты: ниже 200704 при OOM; выше — только если влезает в VRAM.
MAX_MODEL_LEN=200704

# Что: --kv-cache-dtype.
# Для чего: KV M2, FP8-ориентир в рецепте.
# Варианты: fp8_e4m3, auto — при проблемах.
KV_CACHE_DTYPE=fp8_e4m3

# Что: --gpu-memory-utilization.
# Для чего: агрессивное использование VRAM на 8×H200.
# Варианты: 0.90–0.95; снижать при OOM.
GPU_MEM_UTIL=0.95

# Что: SGLang --mem-fraction-static.
# Для чего: запас на SGLang-ветку.
# Варианты: 0.90–0.95.
SGLANG_MEM_FRACTION_STATIC=0.92

# Что: vLLM --max-num-batched-tokens.
# Для чего: high throughput, рецепт ориентирует на 8×GPU.
# Варианты: 16384, 24576, 12288 — при OOM.
SLGPU_MAX_NUM_BATCHED_TOKENS=24576

# Что: --tensor-parallel-size (здесь 8, но с EP мульти-эксперт раскрывается иначе — см. рецепт).
# Для чего: 4+4 EP на 8 карт: SLGPU_ENABLE_EXPERT_PARALLEL, маска GPU, TP в репозитории 8 в шаблоне;
#  фактически vLLM комбинация TP4+EP по доке; не ставить «голый» TP8.
# Варианты: согласовать с EP/DP из рецепта vLLM.
TP=8

# Что: --reasoning-parser.
# Для чего: MiniMax M2 family.
# Варианты: minimax_m2.
REASONING_PARSER=minimax_m2

# Что: --tool-call-parser.
# Для чего: согласован с reasoning.
# Варианты: minimax_m2.
TOOL_CALL_PARSER=minimax_m2

# Что: JSON для vLLM --compilation-config: fuse_minimax_qk_norm (PR/рецепт).
# Для чего: обязателен для нормальной производительности M2.7 в образе vLLM с поддержкой fusion.
# Варианты: убрать при несовместимом тега образа (тогда сменить VLLM_DOCKER_IMAGE).
SLGPU_VLLM_COMPILATION_CONFIG='{"mode":3,"pass_config":{"fuse_minimax_qk_norm":true}}'

# Что: 1 = --enable-expert-parallel.
# Для чего: 8×GPU, TP4+EP — см. рецепт; на 4× поставьте 0.
# Варианты: 0 | 1.
SLGPU_ENABLE_EXPERT_PARALLEL=1

# Что: --data-parallel-size (vLLM); для сценария DP8+EP из рецепта.
# Для чего: распределение реплик/батчей; согласовать с TP, EP, числом карт.
# Варианты: раскомментировать 8 и проверить доку/лог; иначе не задавать.
# SLGPU_VLLM_DATA_PARALLEL_SIZE=8

# Что: маска `NVIDIA_VISIBLE_DEVICES` (через docker-compose) — **все** 8 карт.
# Для чего: при TP=4 vLLM иначе увидит только 0..3 без явной маски; EP нужен доступ ко всем 8.
# Варианты: 0,1,2,3,4,5,6,7; на 4×GPU сузить до 0–3.
SLGPU_NVIDIA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7

# Что: имя для бенчмарка.
# Для чего: пусто — авто из /v1/models.
# Варианты: строка alias.
BENCH_MODEL_NAME=
