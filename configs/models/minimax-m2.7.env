# Пресет: MiniMaxAI/MiniMax-M2.7 (MoE, свой формат reasoning-границ).

# Для чего: репозиторий весов на HF.
# Варианты: `MiniMaxAI/MiniMax-M2.7` или актуальный путь релиза.
MODEL_ID=MiniMaxAI/MiniMax-M2.7
# Для чего: закрепить коммит весов.
# Варианты: SHA/тег; пусто — по умолчанию.
MODEL_REVISION=
# Для чего: окно контекста в токенах (длинный контекст стоит VRAM).
# Варианты: 262144 — разумный старт; до 1M только при запасе памяти и снижении SGLANG_MEM_FRACTION_STATIC при необходимости.
MAX_MODEL_LEN=262144
# Для чего: dtype KV.
# Варианты: `fp8_e4m3` / `fp8` для этой модели в типичных настройках.
KV_CACHE_DTYPE=fp8_e4m3
# Для чего: `--gpu-memory-utilization` vLLM.
# Варианты: при OOM снижать по шагам.
GPU_MEM_UTIL=0.9242
# Для чего: статическая доля VRAM в SGLang.
# Варианты: 0.88–0.92; для очень длинного контекста может понадобиться ниже.
SGLANG_MEM_FRACTION_STATIC=0.90
# Для чего: парсер reasoning MiniMax M1/M2.
# Варианты: `minimax_m2` в vLLM/SGLang для этой линейки.
REASONING_PARSER=minimax_m2
# Для чего: парсер tool calls vLLM.
# Варианты: `minimax_m2` для согласованности с семейством.
TOOL_CALL_PARSER=minimax_m2
# Для чего: число GPU под tensor parallel.
# Варианты: обычно 4 на стенде.
TP=4
