# MiniMaxAI/MiniMax-M2.7 (MoE, особенность: генерирует только закрывающий </think>,
# всё до </think> = reasoning_content, после = content).
MODEL_ID=MiniMaxAI/MiniMax-M2.7
MODEL_REVISION=
# MiniMax-M2 поддерживает длинный контекст; 262K — безопасный старт,
# 1M потребует заметно больше VRAM и SGLANG_MEM_FRACTION_STATIC ниже.
MAX_MODEL_LEN=262144
KV_CACHE_DTYPE=fp8_e4m3
GPU_MEM_UTIL=0.9242
SGLANG_MEM_FRACTION_STATIC=0.90
REASONING_PARSER=minimax_m2
TOOL_CALL_PARSER=minimax_m2
TP=4
