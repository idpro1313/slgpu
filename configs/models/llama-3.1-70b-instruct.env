# Llama 3.1 70B Instruct (dense)
MODEL_ID=meta-llama/Llama-3.1-70B-Instruct
MODEL_REVISION=
MAX_MODEL_LEN=131072
# Llama принимает fp8 (обычно fp8_e4m3) или auto/half.
KV_CACHE_DTYPE=fp8_e4m3
GPU_MEM_UTIL=0.9242
SGLANG_MEM_FRACTION_STATIC=0.92
# Нет reasoning-блоков — парсер оставляем пустым.
REASONING_PARSER=
TP=4
