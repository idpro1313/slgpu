# Пресет: Qwen3-30B-A3B (MoE). Контекст на HF: до 131072 с YaRN; 262144 у этой линейки не заявлено.
#
# Что: Docker-образ vLLM, семейство qwen3_5, cu130.
# Для чего: Qwen3-линейка на CUDA 13.x в контейнере; хост Driver 580.
# Варианты: [Hub vllm/vllm-openai](https://hub.docker.com/r/vllm/vllm-openai/tags).
VLLM_DOCKER_IMAGE=vllm/vllm-openai:qwen3_5-x86_64-cu130

# Что: идентификатор весов HF.
# Для чего: ./slgpu pull, имя в API.
# Варианты: org/model; здесь Qwen/Qwen3-30B-A3B.
MODEL_ID=Qwen/Qwen3-30B-A3B

# Что: ревизия HF.
# Для чего: фиксация версии весов.
# Варианты: SHA, тег, пусто.
MODEL_REVISION=

# Что: --max-model-len / --context-length.
# Для чего: до 131072 согласно карточке; выше — риск OOM.
# Варианты: 65536, 131072, ниже — экономия VRAM.
MAX_MODEL_LEN=131072

# Что: dtype KV cache.
# Для чего: vLLM/SGLang хранение KV.
# Варианты: fp8_e4m3, fp8, auto; для Qwen3 в пресетах чаже fp8_e4m3.
KV_CACHE_DTYPE=fp8_e4m3

# Что: vLLM --gpu-memory-utilization.
# Для чего: доля зарезервированной VRAM.
# Варианты: 0.85–0.95; снижать при OOM.
GPU_MEM_UTIL=0.9242

# Что: SGLang --mem-fraction-static.
# Для чего: статический пул SGLang.
# Варианты: 0.85–0.92; снижать при graph OOM.
SGLANG_MEM_FRACTION_STATIC=0.90

# Что: vLLM --max-num-batched-tokens (имя SLGPU_*).
# Для чего: chunked prefill, throughput.
# Варианты: 4096, 8192, 16384; меньше — дешевле по VRAM.
SLGPU_MAX_NUM_BATCHED_TOKENS=8192

# Что: --reasoning-parser.
# Для чего: Qwen3 reasoning.
# Варианты: qwen3; для thinking-вариантов — см. доку.
REASONING_PARSER=qwen3

# Что: --tool-call-parser.
# Для чего: function calling, формат ответа.
# Варианты: hermes (классика для Qwen3 в общем виде), llama3_json, … — смотрите vLLM `ToolParserManager` в образе.
TOOL_CALL_PARSER=hermes

# Что: --tensor-parallel-size.
# Для чего: шард на N GPU.
# Варианты: 1,2,4,8 — по числу карт.
TP=8
