# Пресет: Qwen3-30B-A3B (MoE). Контекст по карточке HF: до 131072 с YaRN; 262144 для этой линейки не заявлено.

# Для чего: репозиторий весов на Hugging Face.
# Варианты: `org/model`; здесь Qwen3-30B-A3B.
MODEL_ID=Qwen/Qwen3-30B-A3B

# Для чего: зафиксировать снимок весов.
# Варианты: SHA / тег / пусто (ветка по умолчанию).
MODEL_REVISION=

# Для чего: макс. длина контекста (токены) для vLLM и SGLang.
# Варианты: до 131072 для этой модели; выше — OOM/ошибки, ниже — экономия VRAM.
MAX_MODEL_LEN=131072

# Для чего: тип хранения KV cache.
# Варианты: `fp8`, `fp8_e4m3`, `auto` (см. доки движка); `fp8_e4m3` — типичный выбор.
KV_CACHE_DTYPE=fp8_e4m3

# Для чего: vLLM `--gpu-memory-utilization` (доля VRAM под веса+KV+актив.).
# Варианты: 0.85–0.95; снижать при OOM.
GPU_MEM_UTIL=0.9242

# Для чего: SGLang `--mem-fraction-static` (доля для статик-буферов/пула).
# Варианты: 0.85–0.92; снижать при OOM или сбоях graph capture.
SGLANG_MEM_FRACTION_STATIC=0.90

# Для чего: vLLM chunked prefill (`--max-num-batched-tokens`); имя `SLGPU_*` избегает Unknown VLLM_* в 0.19+.
# Варианты: 4096, 8192, 16384; меньше — меньше пиковая память, хуже throughput.
SLGPU_MAX_NUM_BATCHED_TOKENS=8192

# Для чего: парсер тегов reasoning в Qwen3.
# Варианты: `qwen3`; для thinking-вариантов — см. доку vLLM/SGLang.
REASONING_PARSER=qwen3

# Для чего: парсер tool/function calling (vLLM/SGLang).
# Варианты: `hermes`, `llama3_json`, `mistral` и др. по версии движка; см. configs/models/README.md.
TOOL_CALL_PARSER=hermes

# Для чего: tensor parallel (число GPU в одной реплике).
# Варианты: 1, 2, 4, 8, …; должно совпадать с `device_ids` в docker-compose.
TP=8
