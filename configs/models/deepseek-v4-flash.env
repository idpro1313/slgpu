# deepseek-ai/DeepSeek-V4-Flash — MoE (284B total / ~13B activated), FP8 веса; карточка HF:
# https://huggingface.co/deepseek-ai/DeepSeek-V4-Flash
# В config.json: max_position_embeddings=1048576 (1M), model_type=deepseek_v4; чат без Jinja —
# кодировка сообщений в репозитории модели (папка encoding). Поддержка vLLM: обзор
# https://vllm.ai/blog/deepseek-v4 — свежий образ: **deepseekv4** + **cu130** (этот пресет).
# Образ vLLM: [Hub](https://hub.docker.com/r/vllm/vllm-openai/tags) — **deepseekv4-x86_64-cu130**.

MODEL_ID=deepseek-ai/DeepSeek-V4-Flash
VLLM_DOCKER_IMAGE=vllm/vllm-openai:deepseekv4-x86_64-cu130
MODEL_REVISION=

# 384K — ориентир для Think Max (карточка: окно ≥384K); полный 1M в config — если хватает VRAM, иначе снижайте при OOM.
MAX_MODEL_LEN=393216
KV_CACHE_DTYPE=auto
GPU_MEM_UTIL=0.90
SGLANG_MEM_FRACTION_STATIC=0.90
SLGPU_MAX_NUM_BATCHED_TOKENS=8192
TP=8
REASONING_PARSER=deepseek_r1
TOOL_CALL_PARSER=pythonic

# KV: auto — vLLM подбирает dtype; при необходимости задайте fp8_e4m3 вручную. Тяжёлый MoE: при OOM понижайте MAX_MODEL_LEN, GPU_MEM_UTIL, SLGPU_MAX_NUM_BATCHED_TOKENS; EP — SLGPU_ENABLE_EXPERT_PARALLEL=1
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0
SLGPU_ENABLE_EXPERT_PARALLEL=0

BENCH_MODEL_NAME=
