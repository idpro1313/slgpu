# Параметры окружения для SGLang (env_file в compose).
# Загрузка: .env → sglang.env → пресет (./slgpu up). Флаги — configs/sglang/serve.sh.

# -------- HTTP внутри контейнера --------
# Для чего: bind адрес сервера SGLang.
# Варианты: 0.0.0.0 или 127.0.0.1.
SGLANG_LISTEN_HOST=0.0.0.0
# Для чего: порт API (совпадает с пробросом 8111).
SGLANG_LISTEN_PORT=8111

# -------- NCCL --------
NCCL_P2P_LEVEL=NVL

# -------- PyTorch (CUDA allocator) --------
# Для чего: меньше фрагментации на MoE.
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
