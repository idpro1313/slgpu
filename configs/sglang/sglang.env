# Параметры окружения для SGLang (env_file в compose).
# Загрузка: .env → sglang.env → пресет (./slgpu up). Флаги — configs/sglang/serve.sh.

# -------- Метрики Prometheus (/metrics) — нужны для оф. Grafana SGLang Dashboard --------
# SGLANG_ENABLE_METRICS=1  # по умолчанию в serve.sh; 0 — отключить
# SGLANG_ENABLE_MFU_METRICS=1  # опционально; панели MFU в дашборде

# -------- HTTP внутри контейнера --------
# Для чего: bind адрес сервера SGLang.
# Варианты: 0.0.0.0 или 127.0.0.1.
SGLANG_LISTEN_HOST=0.0.0.0
# Для чего: порт API внутри контейнера (Prometheus: sglang:8222; проброс LLM_API_PORT → 8222).
SGLANG_LISTEN_PORT=8222

# -------- NCCL --------
NCCL_P2P_LEVEL=NVL

# -------- PyTorch (CUDA allocator) --------
# Для чего: меньше фрагментации на MoE.
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# -------- CUDA graph / torch (serve.sh) --------
# Частые сценарий: RuntimeError / «Capture cuda graph failed… custom_all_reduce» (TP, graph capture).
# Пробовать по шагам: при падении в custom_all_reduce.cuh / get_graph_buffer_ipc_meta — SGLANG_DISABLE_CUSTOM_ALL_REDUCE=1 (NCCL).
# Далее как в SGLang: mem ↓, --cuda-graph-max-bs ↓, torch compile off, затем --disable-cuda-graph.
# SGLANG_MEM_FRACTION_STATIC — в пресете; здесь дубликат не нужен.
# SGLANG_DISABLE_CUSTOM_ALL_REDUCE=1
# SGLANG_CUDA_GRAPH_MAX_BS=16
# SGLANG_ENABLE_TORCH_COMPILE=0
# SGLANG_DISABLE_CUDA_GRAPH=1
