# Параметры окружения для SGLang (env_file в compose).
# Порядок: main.env → этот файл → пресет. NCCL, PyTorch (PYTORCH_CUDA_ALLOC_CONF) — в [main.env](../../main.env).
# Флаги: configs/sglang/serve.sh; булевы через 0/1, если не сказано иначе.

# -------- Метрики Prometheus (/metrics) --------

# Для чего: экспорт sglang:* на /metrics (оф. Grafana SGLang Dashboard).
# Варианты: 1 (по умолчанию в serve.sh) | 0 — не передавать --enable-metrics.
# SGLANG_ENABLE_METRICS=1

# Для чего: доп. метрики MFU (FLOPS/память) в /metrics.
# Варианты: 1 (передаётся --enable-mfu-metrics) | 0; обычно 0, если панели MFU не нужны.
# SGLANG_ENABLE_MFU_METRICS=1

# -------- HTTP внутри контейнера --------

# Для чего: адрес бинда HTTP-сервера SGLang.
# Варианты: 0.0.0.0 (все интерфейсы) | 127.0.0.1.
SGLANG_LISTEN_HOST=0.0.0.0

# Для чего: порт API внутри контейнера; Prometheus скрейп sglang:<этот_порт>, compose маппит LLM_API_PORT → сюда.
# Варианты: в slgpu ожидается 8222; при смене согласуйте docker-compose и monitoring/prometheus.yml.
SGLANG_LISTEN_PORT=8222

# -------- Кэш Triton / TorchInductor (autotune, скомпиленные ядра) --------

# Смонтированный том: docker-compose → /var/cache/slgpu-kernels. Без тома кэш часто в /tmp и пропадает с контейнером.
# При смене драйвера, CUDA, PyTorch, Triton, SGLang при сбоях: docker volume rm slgpu_sglang-kernel-cache

# Для чего: куда Triton сохраняет autotune и бинарники ядер.
# Варианты: любой путь в persist-томе; в slgpu согласовано с volume compose.
TRITON_CACHE_DIR=/var/cache/slgpu-kernels/triton

# Для чего: куда TorchInductor пишет кэш компиляции (AOT, обёртки).
# Варианты: путь в persist-томе; раздельно от TRITON для ясной очистки.
TORCHINDUCTOR_CACHE_DIR=/var/cache/slgpu-kernels/torchinductor

# Для чего: FX graph on-disk cache Inductor (force через env).
# Варианты: не задавать (в PyTorch 2.4+ чаще уже True) | 1 (явно вкл.) | 0 (явно выкл.).
# TORCHINDUCTOR_FX_GRAPH_CACHE=1

# -------- Параметры, которые читает serve.sh (дубли в пресете не нужны) --------

# Подсказка при сбоях: «Capture cuda graph failed… custom_all_reduce». Порядок: SGLANG_DISABLE_CUSTOM_ALL_REDUCE →
# SGLANG_MEM (пресет) ↓, SGLANG_CUDA_GRAPH_MAX_BS ↓, SGLANG_ENABLE_TORCH_COMPILE=0, затем SGLANG_DISABLE_CUDA_GRAPH=1.

# Для чего: флаг --disable-custom-all-reduce (all-reduce через NCCL, не custom kernel).
# Варианты: 0 (по умолчанию) | 1 при get_graph_buffer_ipc_meta / custom_all_reduce.cuh.
# SGLANG_DISABLE_CUSTOM_ALL_REDUCE=1

# Для чего: макс. batch size в CUDA graph capture (`--cuda-graph-max-bs`).
# Варианты: 8, 16, 32; меньше — чаще стабильнее на MoE+TP8.
# SGLANG_CUDA_GRAPH_MAX_BS=16

# Для чего: отключить `--enable-torch-compile` в SGLang (указать 0, no, false в serve).
# Варианты: 1 (дефолт в serve) | 0 при сбоях на compile+capture.
# SGLANG_ENABLE_TORCH_COMPILE=0

# Для чего: полный отказ от CUDA graph (`--disable-cuda-graph`).
# Варианты: 0 (по умолчанию) | 1 (крайняя мера, сильно медленнее).
# SGLANG_DISABLE_CUDA_GRAPH=1
