# Дополнительные переменные окружения процесса SGLang (env_file в compose).
# Основные флаги reasoning/KV/TP задаются в .env и docker-compose.yml.

# Для чего: стратегия аллокатора CUDA в PyTorch (смягчение фрагментации на больших MoE).
# Варианты: обычно `expandable_segments:True`; не заменяет нехватку VRAM под веса на шарде.
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
