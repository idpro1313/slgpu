# Дополнительные переменные окружения для SGLang (необязательно).
# Reasoning-парсер уже включён через REASONING_PARSER в .env (см. docker-compose.yml).

# Меньше фрагментации CUDA при тяжёлых MoE; при OOM на этапе load_model всё равно оставляйте включённым.
# Не заменяет нехватку VRAM на шард (Kimi-K2.6 при TP=4 на 4×~140 GiB — см. configs/models/kimi-k2.6.env).
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
