# Дефолты slgpu: один «базовый» слой до корневого .env, затем configs/<engine>/<engine>.env и пресет.
# Секреты не храните здесь (токены, пароли — в .env / configs/secrets). Редактирование: скопируйте в
# корневой .env или в пресет — там значения сильнее.
#
# Синхрон: плейсхолдеры ${VAR:-…} в docker-compose.yml и ${VAR:-…} в serve.sh отражают эти величины
# (при смене — обновить соответствующие файлы).
#
# Порядок загрузки в скриптах: main.env → .env → (vllm.env|sglang.env при up) → configs/models/<preset>.env

# --- Пути / образ vLLM ---
MODELS_DIR=/opt/models
VLLM_DOCKER_IMAGE=vllm/vllm-openai:latest

# --- Порты публикации API (хост) — LLM_API_PORT при ./slgpu up или в .env ---
LLM_API_BIND=0.0.0.0

# --- Общие для vLLM и SGLang (docker-compose + serve.sh) ---
MAX_MODEL_LEN=32768
TP=8
GPU_MEM_UTIL=0.92
KV_CACHE_DTYPE=fp8_e4m3
SLGPU_MAX_NUM_BATCHED_TOKENS=8192
SLGPU_DISABLE_CUSTOM_ALL_REDUCE=1
SLGPU_ENABLE_PREFIX_CACHING=1
TOOL_CALL_PARSER=hermes
REASONING_PARSER=qwen3
NVIDIA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1
SLGPU_ENABLE_EXPERT_PARALLEL=0

# --- SGLang (compose) ---
SGLANG_MEM_FRACTION_STATIC=0.90
SGLANG_ENABLE_TORCH_COMPILE=1
SGLANG_DISABLE_CUDA_GRAPH=0
SGLANG_DISABLE_CUSTOM_ALL_REDUCE=0
SGLANG_ENABLE_METRICS=1
SGLANG_ENABLE_MFU_METRICS=0

# --- Мониторинг (подставляются в docker compose при export из ./slgpu up) ---
PROMETHEUS_BIND=127.0.0.1
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=0
DCGM_BIND=127.0.0.1
NODE_EXPORTER_BIND=127.0.0.1
GRAFANA_BIND=0.0.0.0
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
