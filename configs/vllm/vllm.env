# Параметры окружения для процесса vLLM в Docker (env_file в compose).
# Порядок через ./slgpu up: .env → vllm.env → пресет. CLI — configs/vllm/serve.sh.

# -------- HTTP-сервер внутри контейнера --------
# Для чего: интерфейс прослушивания OpenAI API.
# Варианты: 0.0.0.0 — все интерфейсы; 127.0.0.1 — только внутри контейнера.
VLLM_LISTEN_HOST=0.0.0.0
# Для чего: порт (согласован с пробросом compose 8111:8111).
# Варианты: обычно 8111 в этом проекте.
VLLM_LISTEN_PORT=8111

# -------- NCCL (как в docker-compose environment) --------
# Для чего: уровень P2P для связи GPU.
# Варианты: NVL, PIX, PHB, SYS — см. документацию NCCL.
NCCL_P2P_LEVEL=NVL
# Для чего: отключение InfiniBand, если нет IB.
# Варианты: 1 — отключить; 0 — разрешить.
NCCL_IB_DISABLE=1

# -------- Логи и память vLLM --------
# Для чего: детальность логов процесса.
# Варианты: DEBUG, INFO, WARNING, ERROR.
VLLM_LOGGING_LEVEL=INFO
# Для чего: учитывать CUDA Graph в профайлере памяти (согласовать с GPU_MEM_UTIL в .env/пресете).
# Варианты: 0 или 1; пресет может задать 0 для тяжёлых MoE.
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1

# -------- PyTorch (процесс в контейнере) --------
# Для чего: снижение фрагментации VRAM на больших MoE.
# Варианты: expandable_segments:True как правило; менять по рекомендациям PyTorch.
PYTORCH_ALLOC_CONF=expandable_segments:True

# Движок v1 (vLLM 0.19+): раскомментируйте при нестабильном v1.
# VLLM_USE_V1=0
