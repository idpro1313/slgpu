# Дополнительные переменные окружения для vLLM.
# Qwen3 Next: KV через compose — KV_CACHE_DTYPE=fp8_e4m3 (не fp8_e5m2).
# Reasoning/thinking-парсер: см. REASONING_PARSER в .env (по умолчанию qwen3).
# trust_remote_code: в compose для vLLM задано --trust-remote-code (нужно для Kimi-K2.x и др. с custom HF code).
# --disable-custom-all-reduce: в docker-compose.yml (обход cuda invalid argument в custom_all_reduce на части GPU/моделей).

# Движок v1 (по умолчанию в 0.19+). Если при старте видите только WorkerProc/Engine core failed без
# понятной причины — раскомментируйте и пересоздайте контейнер vLLM (обход возможных багов v1 на части моделей).
# VLLM_USE_V1=0

# Меньше фрагментации при тяжёлых MoE (Kimi и др.); при OOM на этапе load_model имеет смысл оставить включённым.
PYTORCH_ALLOC_CONF=expandable_segments:True

# Включаем новый профайлер памяти CUDA Graph (станет дефолтом в vLLM 0.19+).
# При этом .env часто держит GPU_MEM_UTIL≈0.9242 (Qwen и др.); для Kimi см. пресет kimi-k2.6 — ниже util.
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1

# Примеры:
# VLLM_LOGGING_LEVEL=DEBUG
# VLLM_USE_V1=1
