# Дополнительные переменные окружения процесса vLLM (подключаются как env_file в compose).

# Для чего: выбор реализации движка vLLM v0 vs v1 (если раскомментировать).
# Варианты: `VLLM_USE_V1=0` — старый путь (если v1 падает без явной ошибки CUDA); `VLLM_USE_V1=1` — явно v1; по умолчанию в образе — как в версии vLLM.
# VLLM_USE_V1=0

# Для чего: стратегия аллокации PyTorch (меньше фрагментации VRAM при больших MoE).
# Варианты: обычно `expandable_segments:True`; менять только при рекомендациях от PyTorch/vLLM для вашей версии.
PYTORCH_ALLOC_CONF=expandable_segments:True

# Для чего: учитывать память CUDA Graph при профилировании KV (влияет на безопасный `GPU_MEM_UTIL`).
# Варианты: `1` — включено (рекомендации vLLM 0.19+); `0` — отключить (тяжёлые MoE, мало запаса VRAM — см. пресет kimi-k2.6).
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1

# Для чего: уровень логов vLLM (отладка старта/oom).
# Варианты: `DEBUG`, `INFO`, `WARNING`, … см. документацию vLLM / стандарт Python logging.
# VLLM_LOGGING_LEVEL=DEBUG
