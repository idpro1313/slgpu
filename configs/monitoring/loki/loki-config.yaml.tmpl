# Шаблон Loki 3.x (TSDB + schema v13, блок common.storage). Рендер backend'ом
# (render_monitoring_configs) в WEB_DATA_DIR/.slgpu/monitoring/loki-config.yaml.
# Апгрейд с Loki 2.x + существующий boltdb-shipper в LOKI_DATA_DIR: см. [Upgrade Loki](https://grafana.com/docs/loki/latest/setup/upgrade/);
# при сбоях — бэкап и очистка каталога или миграция по доке Grafana.
auth_enabled: false

server:
  http_listen_port: ${LOKI_INTERNAL_PORT}
  grpc_listen_port: 0
  log_level: info

# Loki 3: единая точка хранения (см. upstream cmd/loki/loki-local-config.yaml).
common:
  instance_addr: 127.0.0.1
  path_prefix: /loki
  storage:
    filesystem:
      chunks_directory: /loki/chunks
      rules_directory: /loki/rules
  replication_factor: 1
  ring:
    kvstore:
      store: inmemory

analytics:
  reporting_enabled: false

schema_config:
  configs:
    - from: 2020-10-24
      store: tsdb
      object_store: filesystem
      schema: v13
      index:
        prefix: index_
        period: 24h

query_range:
  results_cache:
    cache:
      embedded_cache:
        enabled: true
        max_size_mb: 100

limits_config:
  allow_structured_metadata: false
  reject_old_samples: true
  reject_old_samples_max_age: 168h
  ingestion_rate_mb: 12
  ingestion_burst_size_mb: 24
  retention_period: 720h
  max_query_lookback: 720h
  metric_aggregation_enabled: true
  enable_multi_variant_queries: true

ruler:
  alertmanager_url: http://127.0.0.1:9093

compactor:
  working_directory: /loki/compactor
  compaction_interval: 10m
  retention_enabled: true
  retention_delete_delay: 2h

# Loki 3: поле chunk_store_config.max_look_back_period удалено (нет в ChunkStoreConfig).
# Ограничение глубины запросов — limits_config.max_query_lookback (см. выше).

frontend:
  encoding: protobuf
