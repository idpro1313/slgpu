# Шаблон Promtail. Рендер backend'ом (render_monitoring_configs) в
# WEB_DATA_DIR/.slgpu/monitoring/promtail-config.yml. Образ берётся из stack_params (PROMTAIL_IMAGE).
# Без хардкодов — все значения через плейсхолдеры string.Template ниже.
server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /data/positions.yaml

clients:
  - url: http://${LOKI_SERVICE_NAME}:${LOKI_INTERNAL_PORT}/loki/api/v1/push

scrape_configs:
  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s
    relabel_configs:
      - source_labels: [__meta_docker_container_id]
        regex: (.+)
        target_label: __path__
        replacement: /var/lib/docker/containers/$1/$1-json.log
      - source_labels: [__meta_docker_container_name]
        regex: /(.*)
        target_label: container
      - source_labels: [__meta_docker_container_label_com_docker_compose_service]
        target_label: compose_service
      - source_labels: [__meta_docker_container_label_com_docker_compose_project]
        target_label: compose_project
      - target_label: job
        replacement: docker-logs
    pipeline_stages:
      - docker: {}
