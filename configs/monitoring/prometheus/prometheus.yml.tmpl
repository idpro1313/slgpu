# Шаблон Prometheus. Рендерится backend'ом (render_monitoring_configs) из БД (stack_params)
# в WEB_DATA_DIR/.slgpu/monitoring/prometheus.yml. Compose монтирует именно отрендеренную копию.
# Жёстких имён сервисов / портов / IP здесь быть НЕ должно — все значения берутся из stack_params
# по именам ключей через стандартные плейсхолдеры string.Template (см. ниже по файлу).
# Плейсхолдер ${DCGM_SCRAPE_YAML} подставляет backend целиком (job dcgm или пусто) по MONITORING_DCGM.
global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/prometheus-alerts.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:${PROMETHEUS_INTERNAL_PORT}"]

  # vLLM/SGLang скрейпятся через хост-шлюз: short DNS внутри `${SLGPU_NETWORK_NAME}` для слотов
  # инференса не гарантирован (LLM-слоты — отдельный compose-проект). Используем
  # host.docker.internal:<host port>, поэтому prometheus имеет extra_hosts host-gateway.
  - job_name: vllm
    metrics_path: /metrics
    static_configs:
      - targets: ["host.docker.internal:${LLM_API_PORT}"]
        labels:
          engine: vllm
    relabel_configs:
      - action: replace
        source_labels: [__address__]
        regex: .*
        target_label: instance
        replacement: vllm:${LLM_API_PORT}

  # Дополнительные хост-порты vLLM (мультислотный инференс из UI — у каждого слота свой порт на хосте).
  # Файл vllm-slots.json монтируется рядом с prometheus.yml и НЕ перезаписывается при render_monitoring_configs
  # если уже есть; при первом создании backend подставляет диапазон портов 8110–8130 (см. stack_config).
  # Эндпоинт тот же: /metrics . Неиспользуемые порты в Targets будут DOWN — это нормально.
  # В Grafana vLLM V2 по умолчанию job="vllm" — для слотов используйте job="vllm-slots" или объедините
  # в запросах: job=~"vllm|vllm-slots".
  - job_name: vllm-slots
    metrics_path: /metrics
    file_sd_configs:
      - files:
          - /etc/prometheus/vllm-slots.json
        refresh_interval: 30s
    relabel_configs:
      - source_labels: [__address__]
        regex: ".*:(\\d+)"
        target_label: instance
        replacement: vllm:$$1

  - job_name: sglang
    metrics_path: /metrics
    static_configs:
      - targets: ["host.docker.internal:${LLM_API_PORT_SGLANG}"]
        labels:
          engine: sglang
    relabel_configs:
      - action: replace
        source_labels: [__address__]
        regex: .*
        target_label: instance
        replacement: sglang:${LLM_API_PORT_SGLANG}

${DCGM_SCRAPE_YAML}
  # job=node-exporter — типичный фильтр Grafana «Node Exporter Full» (ID 1860).
  - job_name: node-exporter
    static_configs:
      - targets: ["${NODE_EXPORTER_SERVICE_NAME}:${NODE_EXPORTER_INTERNAL_PORT}"]
        labels:
          instance: host
