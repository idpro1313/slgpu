# =====================================================================
# slgpu — bootstrap для `./slgpu web up`
# =====================================================================
#
# Назначение файла:
#   Минимальный набор переменных, необходимых docker compose для
#   `docker/docker-compose.web.yml` ДО того, как пользователь нажмёт
#   «Импорт настроек» в UI и заполнит SQLite (`stack_params`).
#
#   Используется ТОЛЬКО в host-bash:
#     ./slgpu web up      → docker compose --env-file configs/bootstrap.env
#     ./slgpu web restart → то же самое
#
#   Backend (slgpu-web) этот файл не читает: при работе берёт стек из БД,
#   а при отсутствии параметра — возвращает 4xx и подсказывает заполнить
#   через UI. Полный шаблон импорта — `configs/main.env`.
#
# Что должно быть здесь:
#   - всё, на что ссылается `${VAR}` в compose-web.yml;
#   - сетевые имена / id проектов compose, чтобы web мог сам себя видеть.
#
# Что НЕ должно быть здесь:
#   - конфигурация мониторинга / прокси / инференса
#     (она — в БД, заполняется через UI или импортом `configs/main.env`).
# =====================================================================


# --- Сеть Docker ---

# Имя внешней Docker-сети, общей для web + monitoring + proxy + LLM.
SLGPU_NETWORK_NAME=slgpu

# Имена compose-проектов. Должны совпадать с теми, что вписываются
# в БД при импорте `configs/main.env` (стек ищет себя по labels).
WEB_COMPOSE_PROJECT_INFER=slgpu
WEB_COMPOSE_PROJECT_MONITORING=slgpu-monitoring
WEB_COMPOSE_PROJECT_PROXY=slgpu-proxy


# --- Web UI (slgpu-web) ---

# Образ Docker для slgpu-web (собирается локально командой `./slgpu web up`).
WEB_DOCKER_IMAGE=slgpu-web:dev

# Имя контейнера web (фиксируем ради backend-самопроверок).
WEB_CONTAINER_NAME=slgpu-web

# Внутренний порт uvicorn в контейнере. Mapping: WEB_BIND:WEB_PORT:WEB_INTERNAL_PORT.
WEB_INTERNAL_PORT=8000

# Bind-адрес опубликованного порта web на хосте (0.0.0.0 / 127.0.0.1 / IP).
WEB_BIND=0.0.0.0

# Опубликованный порт web на хосте.
WEB_PORT=8089

# Уровень логов uvicorn / приложения (DEBUG | INFO | WARNING | ERROR).
WEB_LOG_LEVEL=INFO

# 0/1 — писать ли логи приложения в `${WEB_DATA_DIR}/.slgpu/app.log`.
# По умолчанию выключено: события структурированно пишутся в SQLite.
WEB_LOG_FILE_ENABLED=false

# Hostname для health-проб мониторинга и LLM **из контейнера** slgpu-web.
# 127.0.0.1 указывало бы на сам web → используем шлюз хоста.
WEB_MONITORING_HTTP_HOST=host.docker.internal
WEB_LLM_HTTP_HOST=host.docker.internal


# --- Пути на хосте (bind mount) ---

# Каталог хранилища весов (bind в slgpu-web и в LLM-слот).
MODELS_DIR=./data/models

# Каталог пресетов *.env (рабочая копия; источник правды — БД).
PRESETS_DIR=./data/presets

# Каталог данных Web UI (SQLite + secrets + .slgpu/compose-service.env).
WEB_DATA_DIR=./data/web
