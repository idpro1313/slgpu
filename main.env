# Дефолты slgpu: базовый слой в корне репо, затем пресет модели (configs/models/<preset>.env).
# Секреты (пароль Grafana и т.п.) — через export на хосте перед ./slgpu up или раскомментируйте
# строки ниже в локальном main.env на сервере; не коммитьте реальные пароли в публичный репозиторий.
# Параметры конкретной модели — только в configs/models/<preset>.env.
#
# Синхрон: плейсхолдеры ${VAR:-…} в docker-compose.yml и ${VAR:-…} в serve.sh отражают эти величины
# (при смене — обновить соответствующие файлы).
#
# Порядок загрузки в скриптах: main.env → configs/models/<preset>.env

# --- Пути / образ vLLM ---
MODELS_DIR=/opt/models
# Путь внутри контейнера LLM (volume → /models); должен совпадать с docker-compose
SLGPU_MODEL_ROOT=/models
VLLM_DOCKER_IMAGE=vllm/vllm-openai:latest

# --- Порты публикации API (хост) — LLM_API_PORT при ./slgpu up или здесь ---
LLM_API_BIND=0.0.0.0

# --- Общие для vLLM и SGLang (docker-compose + serve.sh) ---
MAX_MODEL_LEN=32768
TP=8
GPU_MEM_UTIL=0.92
KV_CACHE_DTYPE=fp8_e4m3
SLGPU_MAX_NUM_BATCHED_TOKENS=8192
SLGPU_DISABLE_CUSTOM_ALL_REDUCE=1
SLGPU_ENABLE_PREFIX_CACHING=1
TOOL_CALL_PARSER=hermes
REASONING_PARSER=qwen3
NVIDIA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1
SLGPU_ENABLE_EXPERT_PARALLEL=0

# --- vLLM: HTTP внутри контейнера + логи (serve.sh). Не задавайте лишние VLLM_* — vLLM 0.19+ ругается на «Unknown». ---
SLGPU_VLLM_HOST=0.0.0.0
SLGPU_VLLM_PORT=8111
# Флаги serve: 1 = передать, 0 = не передавать
SLGPU_VLLM_TRUST_REMOTE_CODE=1
SLGPU_VLLM_ENABLE_CHUNKED_PREFILL=1
SLGPU_VLLM_ENABLE_AUTO_TOOL_CHOICE=1
VLLM_LOGGING_LEVEL=INFO

# --- SGLang: HTTP, метрики, графы (serve.sh); Triton/TorchInductor — том sglang-kernel-cache в compose ---
SGLANG_LISTEN_HOST=0.0.0.0
SGLANG_LISTEN_PORT=8222
SGLANG_MEM_FRACTION_STATIC=0.90
SGLANG_ENABLE_TORCH_COMPILE=1
SGLANG_DISABLE_CUDA_GRAPH=0
SGLANG_DISABLE_CUSTOM_ALL_REDUCE=0
SGLANG_ENABLE_METRICS=1
SGLANG_ENABLE_MFU_METRICS=0
TRITON_CACHE_DIR=/var/cache/slgpu-kernels/triton
TORCHINDUCTOR_CACHE_DIR=/var/cache/slgpu-kernels/torchinductor
SGLANG_TRUST_REMOTE_CODE=1

# --- NCCL (оба контейнера vLLM/SGLang; single-node) ---
NCCL_P2P_LEVEL=NVL
NCCL_IB_DISABLE=1

# --- PyTorch CUDA allocator (разные имена переменных в vLLM vs SGLang; одно значение) ---
PYTORCH_ALLOC_CONF=expandable_segments:True
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --- Мониторинг (подставляются в docker compose при export из ./slgpu up) ---
PROMETHEUS_BIND=127.0.0.1
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=0
DCGM_BIND=127.0.0.1
NODE_EXPORTER_BIND=127.0.0.1
GRAFANA_BIND=0.0.0.0
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin

# --- Опционально (секреты / per-host): раскомментируйте на сервере; в compose есть ${VAR:-дефолты} ---
# GRAFANA_ADMIN_PASSWORD=...
# GF_SERVER_ROOT_URL=
# LLM_API_PORT=
# SLGPU_NVIDIA_VISIBLE_DEVICES=
