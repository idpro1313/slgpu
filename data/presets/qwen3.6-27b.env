# Пресет: Qwen/Qwen3.6-27B (dense+hybrid attention+mamba, VL). Throughput на 8×H200: SLGPU_MAX_NUM_BATCHED_TOKENS, GPU_MEM_UTIL.
#
# Что: образ Docker vllm/vllm-openai с семейным тегом qwen3_5.
# Для чего: совпадение веток vLLM с поддержкой Qwen3.5/3.6; CUDA 13.x в контейнере.
# Варианты: другие теги [Hub](https://hub.docker.com/r/vllm/vllm-openai/tags); для Driver 580 — *-cu130.
VLLM_DOCKER_IMAGE=vllm/vllm-openai:qwen3_5-x86_64-cu130

# Что: идентификатор репозитория на Hugging Face.
# Для чего: ./slgpu pull, путь в контейнере, поле model в API.
# Варианты: `org/model`; здесь Qwen/Qwen3.6-27B.
MODEL_ID=Qwen/Qwen3.6-27B

# Что: фиксированная ревизия git на HF.
# Для чего: воспроизводимые веса и отчёты.
# Варианты: commit SHA, тег ветки; пусто — подтягивается default branch.
MODEL_REVISION=

# Что: максимальная длина контекста (токены), --max-model-len.
# Для чего: потолок окна; длинные значения сильно нагружают VRAM.
# Варианты: до заявленного в карточке HF; 262144 — длинный контекст линейки при достаточной VRAM.
MAX_MODEL_LEN=262144

# Что: dtype KV cache (--kv-cache-dtype).
# Для чего: баланс памяти/скорости; qwen3_next-архитектура капризна к e5m2.
# Варианты: `fp8`, `fp8_e4m3`; `fp8_e5m2` у qwen3_next часто даёт RuntimeError — не использовать.
KV_CACHE_DTYPE=fp8_e4m3

# Что: --gpu-memory-utilization: доля VRAM, резервируемая vLLM.
# Для чего: 0.9262 — ориентир в связке с VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1 в main.env.
# Варианты: ~0.90–0.95; снижать при OOM при загрузке или длинных контекстах.
GPU_MEM_UTIL=0.9262

# Что: SGLang --mem-fraction-static.
# Для чего: доля VRAM для статик-буферов SGLang (если движок SGLang).
# Варианты: 0.88–0.92; снижать при OOM или сбоях graph capture.
SGLANG_MEM_FRACTION_STATIC=0.90

# Что: vLLM --max-num-batched-tokens; префикс SLGPU_* избегает «Unknown VLLM_*» в 0.19+.
# Для чего: chunked prefill, throughput под нагрузкой.
# Варианты: 4096, 8192, 16384, 32768; на H200+long context часто 16384+.
SLGPU_MAX_NUM_BATCHED_TOKENS=16384

# Что: --reasoning-parser.
# Для чего: выделение рассуждений в Qwen3.
# Варианты: `qwen3`; у веток *-Thinking — см. vLLM `qwen3-thinking` при необходимости.
REASONING_PARSER=qwen3

# Что: --tool-call-parser.
# Для чего: разбор function calling; Qwen3.6 Coder family отдаёт XML, не JSON.
# Варианты:
#   - `qwen3_xml` (vLLM ≥0.12, streaming-friendly; vllm#25028);
#   - `qwen3_coder` (карточка HF, non-streaming fallback).
# Не использовать `hermes` — JSONDecodeError на XML и зависание стрима.
TOOL_CALL_PARSER=qwen3_xml

# Что: --tensor-parallel-size.
# Для чего: шард инференса на N GPU; должно совпадать с фактически выданными в контейнер картами.
# Варианты: 1…N; на 4×GPU — TP=4, на 8× — 8.
TP=8
