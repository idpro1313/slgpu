# deepseek-ai/DeepSeek-V4-Flash — MoE (~284B / ~13B act), FP8; карточка: https://huggingface.co/deepseek-ai/DeepSeek-V4-Flash
# model_type=deepseek_v4, max_position_embeddings=1M; чат: папка encoding. Поддержка: https://vllm.ai/blog/deepseek-v4
#
# Что: HF id.
# Для чего: pull, API.
# Варианты: deepseek-ai/DeepSeek-V4-Flash.
MODEL_ID=deepseek-ai/DeepSeek-V4-Flash

# Что: Docker-образ vLLM, семейство deepseekv4, cu130, x86_64.
# Для чего: v4-специфичные пути; свежий тег w.r.t. блогу v4.
# Варианты: deepseekv4-x86_64-cu130, deepseekv4-cu130.
VLLM_DOCKER_IMAGE=vllm/vllm-openai:deepseekv4-x86_64-cu130

# Что: пин весов HF.
# Для чего: воспроизводимость.
# Варианты: SHA, тег, пусто.
MODEL_REVISION=

# Что: --max-model-len.
# Для чего: 384K/1M в карточке HF — vLLM V1 на 8×H200 с TP8 не резервирует KV на полный 1M; 393K давало тяжёлый/нестабильный старт
# (в т.ч. путь _set_compile_ranges → flashinfer) и вылет по KV, как у Pro. Здесь 256K вровень с deepseek-v4-pro.env.
# Варианты: 196608, 262144, 393216 (только при запасе VRAM и проверке KV); ниже — больше слотов/стабильнее.
MAX_MODEL_LEN=262144

# Что: --kv-cache-dtype. DeepseekV4 в vLLM: только fp8* (assert при auto).
# Для чего: MoE v4 KV.
# Варианты: fp8 (здесь) | fp8_e4m3; не auto.
KV_CACHE_DTYPE=fp8

# Что: vLLM --attention-backend; по умолчанию — fp8_ds_mla KV (INFO в логе).
# Для чего: альтернатива — FLASHINFER_MLA_SPARSE для «стандартного» fp8 KV (см. vLLM).
#SLGPU_VLLM_ATTENTION_BACKEND=FLASHINFER_MLA_SPARSE

# Что: --gpu-memory-utilization. Выровнено с Pro: V1 требует KV на одну последовательность max_model_len.
# Для чего: 256K MoE; при OOM снижать util или MAX_MODEL_LEN.
# Варианты: 0.90–0.95; см. Pro-пресет.
GPU_MEM_UTIL=0.94

# Что: SGLang --mem-fraction-static.
# Для чего: ветка SGLang; близко к GPU_MEM_UTIL.
# Варианты: 0.90–0.95.
SGLANG_MEM_FRACTION_STATIC=0.94

# Что: vLLM --max-num-batched-tokens.
# Для чего: prefill/throughput; ориентир как у Pro (256K окно).
# Варианты: 8192, 12288, 16384; при OOM — ниже.
SLGPU_MAX_NUM_BATCHED_TOKENS=12288

# Что: --tensor-parallel-size.
# Для чего: 8× GPU в slgpu-шаблоне.
# Варианты: 8 или меньше; при EP/шардировании — согласовать с vLLM.
TP=8

# Что: --reasoning-parser.
# Для чего: vLLM: deepseek_v4 для семейства V4; см. https://vllm.ai/blog/deepseek-v4
# Варианты: deepseek_v4
REASONING_PARSER=deepseek_v4

# Что: --tool-call-parser.
# Для чего: V4-совместимый парсер (блог vLLM).
# Варианты: deepseek_v4
TOOL_CALL_PARSER=deepseek_v4

# Что: vLLM --tokenizer-mode.
# Для чего: рецепт V4.
SLGPU_VLLM_TOKENIZER_MODE=deepseek_v4

# Что: vLLM --max-num-seqs; как у Pro — явный лимит параллельных цепочек.
# Варианты: 64, 128, …; при OOM понижать.
SLGPU_VLLM_MAX_NUM_SEQS=128

# Что: vLLM --block-size; блог V4 / DEEPSEEK_SPARSE_SWA 256.
SLGPU_VLLM_BLOCK_SIZE=256

# Что: vLLM --compilation-config. Здесь **не задано** (дефолты движка).
# Для чего: полный рецепт `cudagraph_mode` + `custom_ops:["all"]` как у Pro на части
# образов дал `torch._inductor.InductorError` (replace_by_example) при `profile_run`.
# Поднять вручную — скопировать из deepseek-v4-pro.env; при Inductor — `SLGPU_VLLM_ENFORCE_EAGER=1`.
#SLGPU_VLLM_COMPILATION_CONFIG='{"cudagraph_mode":"FULL_AND_PIECEWISE","custom_ops":["all"]}'

# Что: 1 = vLLM --enforce-eager (без piecewise AOT / torch Inductor на forward; медленнее, стабильнее).
# Для чего: без кастомного SLGPU_VLLM_COMPILATION_CONFIG движок всё равно даёт VLLM_COMPILE + fusion; на части
# стеков — torch._inductor InductorError (replace_by_example) в determine_available_memory / profile_run.
# По умолчанию 1; 0 — попробовать compile, если на вашем torch+vllm путь зелёный.
SLGPU_VLLM_ENFORCE_EAGER=1

# Что: 0/1 — vLLM memory profiler для оценки CUDA graphs при старте.
# Для чего: 0 — быстрее старт тяжёлого MoE, грубее оценка; 1 — дольше старт, точнее.
# Варианты: 0 (здесь) | 1.
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0

# Что: 1 = --enable-expert-parallel.
# Для чего: Flash часто 0; при OOM/рецепте vLLM можно включить 1 (согласовать TP/GPU).
# Варианты: 0 (здесь) | 1.
SLGPU_ENABLE_EXPERT_PARALLEL=0

# Что: поле `model` в bench, если задано.
# Для чего: явный alias; пусто — первая из /v1/models.
# Варианты: пусто или строка.
BENCH_MODEL_NAME=
