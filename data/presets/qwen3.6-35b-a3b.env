# Пресет: Qwen3.6-35B-A3B (MoE, VL: hybrid attention+mamba). Tool calling: по необходимости уточнить TOOL_CALL_PARSER (см. qwen3.6-27b и README).
# Наследование: строки, которых нет ниже, берутся из main.env (hermes, SLGPU_*, BENCH_*, и т.д.) — при vLLM для Qwen3.6 рекомендуется продублировать TOOL_CALL_PARSER=qwen3_xml, как в qwen3.6-27b.env.
#
# Что: Docker-образ vLLM, семейство qwen3_5, CUDA 13.x.
# Для чего: совпадение с поддержкой Qwen3.5/3.6; хост x86_64, Driver 580.
# Варианты: теги [Hub](https://hub.docker.com/r/vllm/vllm-openai/tags).
VLLM_DOCKER_IMAGE=vllm/vllm-openai:qwen3_5-x86_64-cu130

# Что: HF id весов.
# Для чего: pull, путь, имя model в /v1/models.
# Варианты: org/model; здесь Qwen/Qwen3.6-35B-A3B.
MODEL_ID=Qwen/Qwen3.6-35B-A3B

# Что: пин к ревизии HF.
# Для чего: воспроизводимость.
# Варианты: SHA, тег; пусто — default ветка.
MODEL_REVISION=

# Что: --max-model-len, окно в токенах.
# Для чего: лимит контекста SGLang/vLLM.
# Варианты: по карточке до 262144; меньше — если не хватает VRAM.
MAX_MODEL_LEN=262144

# Что: dtype KV.
# Для чего: Qwen3-Next/3.6; избегать e5m2 на части кернелов.
# Варианты: fp8, fp8_e4m3; не fp8_e5m2.
KV_CACHE_DTYPE=fp8_e4m3

# Что: --gpu-memory-utilization.
# Для чего: пул VRAM vLLM; 35B MoE плотнее по памяти, чем 27B dense.
# Варианты: ~0.90–0.95 с профайлером; снижать при OOM.
GPU_MEM_UTIL=0.9242

# Что: SGLang mem-fraction-static.
# Для чего: SGLang-движок; держим совместимым с пресетом при смене движка.
# Варианты: 0.88–0.92.
SGLANG_MEM_FRACTION_STATIC=0.90

# Что: vLLM --max-num-batched-tokens.
# Для чего: пропускная способность chunked prefill.
# Варианты: 4096–16384+; 8192 — компромисс для 35B MoE.
SLGPU_MAX_NUM_BATCHED_TOKENS=8192

# Что: --reasoning-parser.
# Для чего: Qwen3 reasoning.
# Варианты: qwen3, при thinking-чекпоинтах — уточнить в доке vLLM.
REASONING_PARSER=qwen3

# Что: --tensor-parallel-size.
# Для чего: число GPU шарда.
# Варианты: 1…N, кратно доступным в контейнере GPU; на 4× — 4.
TP=8
