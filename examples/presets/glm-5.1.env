# zai-org/GLM-5.1 (bf16). Меньше VRAM: пресет glm-5.1-fp8 + [GLM/GLM5.md](https://github.com/vllm-project/recipes/blob/main/GLM/GLM5.md)
# Sparse MLA+DSA: fp8 KV в vLLM 0.19 несовместим — только auto (README troubleshooting).
#
# Что: Docker-образ vLLM с тегом glm51, CUDA 13.x, x86_64.
# Для чего: рецепт GLM-5.x; не использовать «голый» latest.
# Варианты: [Hub](https://hub.docker.com/r/vllm/vllm-openai/tags) glm51-*-cu130.
VLLM_DOCKER_IMAGE=vllm/vllm-openai:glm51-x86_64-cu130

# Что: HF id репозитория весов.
# Для чего: pull, путь в /models, имя в API.
# Варианты: zai-org/GLM-5.1 (bf16); для FP8 — другой пресет.
MODEL_ID=zai-org/GLM-5.1

# Что: ревизия ветки HF.
# Для чего: воспроизводимость.
# Варианты: SHA, тег; пусто — default.
MODEL_REVISION=

# Что: --max-model-len.
# Для чего: потолок из config — 202752; bf16 MoE на 8×140GB может OOM раньше (SharedFusedMoE).
# Варианты: 65536 → 131072 → 202752 по мере проверки nvidia-smi.
MAX_MODEL_LEN=65536

# Что: --kv-cache-dtype.
# Для чего: FLASHMLA_SPARSE + fp8 даёт «No valid attention backend» — нужен auto.
# Варианты: auto (здесь); не fp8_e4m3 для sparse MLA в 0.19.
KV_CACHE_DTYPE=auto

# Что: --gpu-memory-utilization.
# Для чего: меньше — больше места под веса bf16 MoE; vLLM может просить lower for weights.
# Варианты: 0.70–0.75 старт; 0.72, 0.70 при OOM.
GPU_MEM_UTIL=0.75

# Что: SGLang --mem-fraction-static.
# Для чего: при переключении на SGLang.
# Варианты: 0.85–0.92.
SGLANG_MEM_FRACTION_STATIC=0.90

# Что: vLLM --max-num-batched-tokens.
# Для чего: bf16 MoE тяжёлый — консервативный батч.
# Варианты: 4096, 8192; повышать после стабильного старта.
MAX_NUM_BATCHED_TOKENS=4096

# Что: кэш общих префиксов (флаг в serve: 0 → --no-enable-prefix-caching).
# Для чего: у GLM в репозитории ENABLE_PREFIX_CACHING=0 (sparse/стабильность).
# Варианты: 0 | 1; при конфликте с дефолтом vLLM нужна явная строка в compose.
ENABLE_PREFIX_CACHING=0

# Что: --tensor-parallel-size.
# Для чего: 8× GPU в шаблоне slgpu.
# Варианты: кратно числу карт.
TP=8

# Что: --reasoning-parser.
# Для чего: GLM-5.1 bf16 ветка.
# Варианты: glm45 (как у нативного bf16 в рецепте).
REASONING_PARSER=glm45

# Что: --tool-call-parser.
# Для чего: GLM tool calling (bf16).
# Варианты: glm45; у FP8 часто glm47 — см. glm-5.1-fp8.env.
TOOL_CALL_PARSER=glm45

# Что: опциональное имя модели для бенча (bench_openai и т.д.).
# Для чего: если пусто — берётся первая из /v1/models.
# Варианты: строка alias; пусто — авто.
BENCH_MODEL_NAME=
