# Пресет: moonshotai/Kimi-K2.6 (MoE, long context). OOM / CUDA graph: main.env (SGLANG_*) и комментарии ниже.
#
# Что: Docker-образ vLLM без семейного тега Kimi — стабильная ветка v0.19.1 + cu130 + x86_64.
# Для чего: современный vLLM на CUDA 13.x в контейнере; хост Driver 580.
# Варианты: [Hub](https://hub.docker.com/r/vllm/vllm-openai/tags); смена тега — вместе с тестом API.
VLLM_DOCKER_IMAGE=vllm/vllm-openai:v0.19.1-x86_64-cu130

# Что: HF id.
# Для чего: pull, имя модели.
# Варианты: moonshotai/Kimi-K2.6.
MODEL_ID=moonshotai/Kimi-K2.6

# Что: ревизия HF.
# Для чего: пин весов.
# Варианты: SHA, тег, пусто.
MODEL_REVISION=

# Что: --max-model-len / --context-length.
# Для чего: 262k — длинный контекст; дорого по VRAM.
# Варианты: 131072, 262144, ниже при OOM.
MAX_MODEL_LEN=262144

# Что: dtype KV (SGLang/vLLM).
# Для чего: плотность KV; SGLang у Kimi в пресетах fp8_e4m3.
# Варианты: fp8_e4m3, auto.
KV_CACHE_DTYPE=fp8_e4m3

# Что: --reasoning-parser / SGLang аналог.
# Для чего: теги ``<|think|>``/redacted, линейка Kimi.
# Варианты: kimi_k2.
REASONING_PARSER=kimi_k2

# Что: --tool-call-parser.
# Для чего: согласован с reasoning; иначе рассинхрон с API.
# Варианты: kimi_k2.
TOOL_CALL_PARSER=kimi_k2

# Что: --tensor-parallel-size.
# Для чего: шард на 8 карт (шаблон H200x8).
# Варианты: по числу выданных GPU.
TP=8

# Что: SGLang --mem-fraction-static.
# Для чего: MoE+TP8 — ниже, чем дефолт main, для стабильности graph.
# Варианты: 0.70–0.90; 0.78 — компромисс из пресета.
SGLANG_MEM_FRACTION_STATIC=0.78

# Что: SGLang --cuda-graph-max-bs.
# Для чего: предел batch при захвате CUDA graph.
# Варианты: 8, 16, 32; меньше — стабильнее.
SGLANG_CUDA_GRAPH_MAX_BS=16

# Что: 1 = SGLang --disable-custom-all-reduce.
# Для чего: обход Get_graph_buffer_ipc_meta / custom_all_reduce.cuh на H200+TP+graph.
# Варианты: 0 (NCCL off в других стеках) | 1 (здесь для Kimi).
SGLANG_DISABLE_CUSTOM_ALL_REDUCE=1

# Что: vLLM --gpu-memory-utilization (для SGLang не используется, но в пресете при переключении на vLLM).
# Для чего: единая точка настройки «жирности» пула.
# Варианты: 0.85–0.95.
GPU_MEM_UTIL=0.90

# Что: vLLM --mm-encoder-tp-mode (multimodal encoder).
# Для чего: референс Moonshot/док: режим `data` для раскладки энкодера по GPU.
# Варианты: data, … — см. vLLM --help; пусто — не передавать.
MM_ENCODER_TP_MODE=data

# Примечание: MAX_NUM_BATCHED_TOKENS, ENABLE_PREFIX_CACHING и др. vLLM-поля, если не задать
# в этом пресете, приходят из main.env; при vLLM тюнинге продублируйте в пресете явно (см. соседние .env).

# Что: закомментированные аварийные флаги SGLang.
# Для чего: SGLANG_ENABLE_TORCH_COMPILE=0 — если падает compile; SGLANG_DISABLE_CUDA_GRAPH=1 — last resort (медленно).
# Варианты: раскомментировать по одному при сбоях.
# SGLANG_ENABLE_TORCH_COMPILE=0
# SGLANG_DISABLE_CUDA_GRAPH=1
