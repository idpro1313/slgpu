# google/gemma-4-31B-it — dense VL (~31B), текст + изображения (+ видео кадрами в HF-примере), BF16; контекст до **256K** tokens (карточка HF).
# Карточка: https://huggingface.co/google/gemma-4-31B-it
#
# Инференс через **vLLM** и парсеры семейства **gemma4** (--reasoning-parser / --tool-call-parser), см.
# [Gemma 4 Usage Guide — vLLM Recipes](https://docs.vllm.ai/projects/recipes/en/latest/Google/Gemma4.html).
# При выборе слота с движком **SGLang** парсеры `gemma4` в текущем [`scripts/serve.sh`](../../scripts/serve.sh)
# не эквивалентны полной поддержке инструментов как у vLLM — для этого пресета задаётте слот **vLLM**.
#
# Известные ограничения сборок vLLM см. обсуждение reasoning/tool и `<|channel|>` в репозитории vLLM при необходимости.
#
# Что: Docker-образ vLLM OpenAI-сервера.
# Для чего: поддержка архитектуры Gemma 4 и парсеров **gemma4** обычно требует **актуального** тега образа vLLM
# (сверьтесь с рецептом по ссылке выше и [тегами Hub](https://hub.docker.com/r/vllm/vllm-openai/tags)).
# Варианты: при ошибке вида unknown parser **gemma4** — обновите образ до версии из рецепта.
VLLM_DOCKER_IMAGE=vllm/vllm-openai:v0.19.1-x86_64-cu130

# Что: HF id.
# Для чего: pull, путь к весам под `MODELS_DIR`.
MODEL_ID=google/gemma-4-31B-it

# Что: пин ревизии HF.
# Для чего: воспроизводимость.
MODEL_REVISION=

# Что: --max-model-len.
# Для чего: в карточке — до **256K**; 262144 укладывается в типичный лимит конфигов при 8×H200.
# Варианты: 131072, 196608; ниже — при OOM или если не нужен длинный контекст.
MAX_MODEL_LEN=262144

# Что: dtype KV.
# Для чего: экономия VRAM на длинных контекстах.
# Варианты: fp8_e4m3, auto — при несовместимости с вашей связкой vLLM+моделью.
KV_CACHE_DTYPE=fp8_e4m3

# Что: --gpu-memory-utilization.
# Для чего: VL 31B на 8×GPU с TP8; снижать при OOM загрузки весов/мультимодального энкодера.
GPU_MEM_UTIL=0.92

# Что: --max-num-batched-tokens (chunked prefill).
# Для чего: баланс throughput / память при длинных окнах.
MAX_NUM_BATCHED_TOKENS=16384

# Что: --tensor-parallel-size.
# Для чего: шард модели; 31B dense типично TP8 на 8×H200 в шаблоне slgpu.
TP=8

# Что: vLLM --mm-encoder-tp-mode.
# Для чего: распределение ViT-подсистемы по GPU (ориентир как у других multimodal-пресетов в репо).
MM_ENCODER_TP_MODE=data

# Что: 1 = --trust-remote-code.
# Для чего: кастомные классы/transformers-дорожки из HF-репозитория модели.
TRUST_REMOTE_CODE=1

# Что: vLLM --reasoning-parser (режим «thinking», токены <|channel|> в модели семейства Gemma 4).
# Для чего: разделение рассуждений в OpenAI-совместимом API при поддержке сборки vLLM.
# Варианты: см. [`gemma4_reasoning_parser` в доке vLLM](https://docs.vllm.ai/en/latest/api/vllm/reasoning/gemma4_reasoning_parser/).
REASONING_PARSER=gemma4

# Что: vLLM --tool-call-parser.
# Для чего: сериализация вызовов инструментов Gemma 4 (не общий JSON; см. рецепт).
TOOL_CALL_PARSER=gemma4

# Что: 1 = --enable-auto-tool-choice.
# Для чего: рекомендуется рецептом Gemma 4 совместно с tool parser.
ENABLE_AUTO_TOOL_CHOICE=1

# Что: SGLang --mem-fraction-static (если слот когда-то переключите на SGLang — параметр присутствует ориентиром).
SGLANG_MEM_FRACTION_STATIC=0.90

# Что: маска GPU под TP8 по умолчанию.
NVIDIA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7

# Что: поле model в бенче; пусто — взять из `/v1/models`.
BENCH_MODEL_NAME=
