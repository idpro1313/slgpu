# XiaomiMiMo/MiMo-V2.5 — sparse MoE (~310B / ~15B акт.), омнимодальность (custom_code), контекст до 1M в карточке HF.
# Карточка: https://huggingface.co/XiaomiMiMo/MiMo-V2.5
#
# Движок: в [деплое из карточки HF](https://huggingface.co/XiaomiMiMo/MiMo-V2.5) рекомендован **SGLang**
# (расширенный пример с DeepEP, DP, MTP, multimodal — см. SGLang MiMo-V2.5 cookbook / sgl-project/sglang).
# В этом репозитории [`scripts/serve.sh`](../../scripts/serve.sh) передаёт в SGLang только базовый набор флагов
# (--model-path, --tp, --mem-fraction-static, --context-length, parsers, KV, метрики, trust-remote-code).
# Полный промышленный рецепт (FA3, --moe-*, multimodal encoder и т.д.) потребует доработки entrypoint или
# ручного `docker compose`/`sglang.launch_server`; для старта в slgpu выберите слот с движком **SGLang**.
#
# Образ **vLLM** ниже — запасной; официально для MiMo-V2/v2.5 ориентир — [vLLM MiMo cookbook](https://docs.vllm.ai)
# и семейство **MiMo-V2-Flash**, образ может понадобиться новее образа ниже — проверяйте тег на Hub.
#
# Что: Docker-образ vLLM для ветки vLLM (если слот с движком vLLM).
# Для чего: синхронизация версии CUDA/драйвера с остальными пресетами репо.
# Варианты: [vllm/vllm-openai tags](https://hub.docker.com/r/vllm/vllm-openai/tags); новее при необходимости поддержки MiMo.
VLLM_DOCKER_IMAGE=vllm/vllm-openai:v0.19.1-x86_64-cu130

# Что: HF id.
# Для чего: pull, путь модели в `MODELS_DIR`.
# Варианты: XiaomiMiMo/MiMo-V2.5 (1M ctx); более лёгкий вариант — [MiMo-V2.5-Base](https://huggingface.co/XiaomiMiMo/MiMo-V2.5-Base) (256K).
MODEL_ID=XiaomiMiMo/MiMo-V2.5

# Что: ревизия HF.
# Для чего: фиксация весов.
# Варианты: SHA, тег; пусто — default branch.
MODEL_REVISION=

# Что: --max-model-len / SGLang --context-length.
# Для чего: карточка заявляет до **1M** токенов; в официальном примере SGLang указано **262144** —
# практичный ориентир на 8×H200 перед разгоном окна при проверке KV/OOM.
# Варианты: 131072, 262144; 393216+, 524288+, 1048576 — только при верификации памяти и движка.
MAX_MODEL_LEN=262144

# Что: --kv-cache-dtype (vLLM и SGLang).
# Для чего: экономия памяти; у омнимодальных кастомных стеков при сбоях попробуйте `auto`.
# Варианты: fp8_e4m3, fp8, auto — по логам vLLM/SGLang.
KV_CACHE_DTYPE=fp8_e4m3

# Что: vLLM --gpu-memory-utilization.
# Для чего: слот на vLLM; MoE-сценарии — после проверки, что поддержка есть в вашем образе.
# Варианты: 0.88–0.94; ниже при OOM.
GPU_MEM_UTIL=0.92

# Что: SGLang --mem-fraction-static.
# Для чего: официальный пример SGLang на HF использует **0.65**; здесь значение совпадает с рецептом карточки.
# Варианты: поднимать аккуратно при запасе VRAM; иметь в виду OOM multimodal/MM encoder.
SGLANG_MEM_FRACTION_STATIC=0.65

# Что: vLLM --max-num-batched-tokens.
# Для чего: chunked prefill; ориентир как у официального примера (--chunked-prefill-size 16384).
# Варианты: 8192, 12288, 16384; при OOM снижать.
MAX_NUM_BATCHED_TOKENS=16384

# Что: --tensor-parallel-size / SGLang --tp.
# Для чего: шард модели по GPU (карточка: TP 8 для примера SGLang).
# Варианты: число доступных GPU; DP/DeepEP из полного примера HF сюда не мапится — см. SGLang cookbook.
TP=8

# Что: 1 — SGLang/vLLM --trust-remote-code (в карточке: обязательно для multimodal/custom code).
# Для чего: загрузка кода модели из репозитория HF.
SGLANG_TRUST_REMOTE_CODE=1

# Что: --reasoning-parser (карточка HF для SGLang: **qwen3**).
# Для чего: разметка рассуждений.
REASONING_PARSER=qwen3

# Что: --tool-call-parser (карточка HF для SGLang: **mimo**).
# Для чего: парсинг вызовов инструментов в линейке MiMo.
TOOL_CALL_PARSER=mimo

# Что: --served-model-name (пустое в serve.sh → MODEL_ID): явный alias как в официальной команде (--served-model-name mimo-v2.5).
# Для чего: имя в `/v1/models` и клиентах.
SERVED_MODEL_NAME=mimo-v2.5

# Что: верхняя граница CUDA graph batch в SGLang (если задано).
# Для чего: большие MoE часто режут BS для stability graph capture.
SGLANG_CUDA_GRAPH_MAX_BS=16

# Что: маска всех GPU (как число процессоров совпадает с TP для примера 8GPU).
NVIDIA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7

# Что: поле model в бенче.
# Для чего: совпадение с именем в API после SERVED_MODEL_NAME.
BENCH_MODEL_NAME=mimo-v2.5
