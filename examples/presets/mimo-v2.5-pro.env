# XiaomiMiMo/MiMo-V2.5-Pro — flagship MoE (~1.02T / ~42B active), 1M context, native FP8.
# Recipe: https://recipes.vllm.ai/XiaomiMiMo/MiMo-V2.5-Pro?features=tool_calling%2Creasoning%2Cspec_decoding
# Card: https://huggingface.co/XiaomiMiMo/MiMo-V2.5-Pro
#
# Stable vLLM does not yet support MiMo V2.5; the recipe requires this prebuilt image.
VLLM_DOCKER_IMAGE=vllm/vllm-openai:mimov25-cu129

# HF id.
MODEL_ID=XiaomiMiMo/MiMo-V2.5-Pro

# Pin HF revision if needed; empty means default branch.
MODEL_REVISION=

# vLLM recipe uses --max-model-len auto; full advertised context is 1,048,576.
MAX_MODEL_LEN=auto

# FP8 KV keeps the 1M-context model practical on H200-class GPUs.
KV_CACHE_DTYPE=fp8_e4m3

# Recipe value for TP8 on 8x H200.
GPU_MEM_UTIL=0.95

# Keep SGLang fallback conservative if the preset is used with an SGLang slot.
SGLANG_MEM_FRACTION_STATIC=0.65

# Chunked prefill budget; lower to 8192/12288 if activation memory is tight.
MAX_NUM_BATCHED_TOKENS=16384

# Recipe prerequisite: 8x H200 with tensor parallel size 8.
TP=8

# vLLM/SGLang custom model code is required for MiMo.
TRUST_REMOTE_CODE=1
SGLANG_TRUST_REMOTE_CODE=1

# Recipe tool calling + reasoning flags.
TOOL_CALL_PARSER=mimo
REASONING_PARSER=mimo
ENABLE_AUTO_TOOL_CHOICE=1

# Keep vLLM throughput features explicit.
ENABLE_PREFIX_CACHING=1
ENABLE_CHUNKED_PREFILL=1

# All eight GPUs for TP8.
NVIDIA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7

# API and bench alias.
SERVED_MODEL_NAME=mimo-v2.5-pro
BENCH_MODEL_NAME=mimo-v2.5-pro
