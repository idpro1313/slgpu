# Пресет: openai/gpt-oss-120b — MoE-модель OpenAI (Apache 2.0), MXFP4-квантованные веса экспертов.
#
# Карточка: https://huggingface.co/openai/gpt-oss-120b
# vLLM Recipes: https://docs.vllm.ai/projects/recipes/en/latest/OpenAI/GPT-OSS.html
# Tool calling treads: https://github.com/vllm-project/vllm/issues/22337  (#22386 — добавлен `openai` tool parser; #25514 — фиксы chat completions)
#
# Поддерживается на NVIDIA H100/H200/B200 (и AMD MI300x+/Radeon AI PRO R9700) — для Hopper/Blackwell vLLM
# автоматически выбирает оптимальный путь (MXFP4 MoE через FlashInfer на Blackwell, Marlin/Cutlass на Hopper).
# Размер: ~120B (5.1B активных), 128K контекст. На 80 GB H100/H200 «помещается» в TP=1, но **balanced**
# рекомендация vLLM-рецепта — **TP=2 + max_num_seqs=128** (см. ниже).
#
# Чат-формат — Harmony (`<|channel|>...|>`). Парсеры обязательны для корректного reasoning_content / tool_calls
# в OpenAI-совместимом API:
#   --tool-call-parser=openai          (#22386)
#   --reasoning-parser=openai_gptoss   (nightly args, #25514)
#   --enable-auto-tool-choice          (без него vLLM возвращает аргументы tool как plain content)
# `serve.sh` подставит эти значения из ключей TOOL_CALL_PARSER / REASONING_PARSER / ENABLE_AUTO_TOOL_CHOICE ниже.

# Что: Docker-образ vLLM, актуальный для gpt-oss (поддержка `openai_gptoss` reasoning parser добавлена в свежих сборках).
# Для чего: x86_64 / CUDA 13.x — под драйвер 580+ на хосте.
# Варианты: теги [Hub](https://hub.docker.com/r/vllm/vllm-openai/tags); при ошибке `unknown reasoning parser openai_gptoss`
# — обновите образ до последнего стабильного либо nightly (см. упоминания в issue #22337).
VLLM_DOCKER_IMAGE=vllm/vllm-openai:v0.20.1-x86_64-cu130

# Что: HF id весов.
# Для чего: pull, путь под MODELS_DIR, имя в /v1/models (если SERVED_MODEL_NAME пустой).
MODEL_ID=openai/gpt-oss-120b

# Что: пин ревизии HF.
# Для чего: воспроизводимость.
MODEL_REVISION=

# Что: --max-model-len, окно в токенах.
# Для чего: gpt-oss-120b нативно поддерживает 128K (карточка HF).
# Варианты: 131072 (дефолт), 65536/32768 — при OOM или для роста concurrent capacity.
MAX_MODEL_LEN=131072

# Что: dtype KV-кэша.
# Для чего: экономия VRAM на 128K-окне; vLLM-рецепт для Hopper/Blackwell использует fp8 KV.
# Варианты: fp8 / fp8_e4m3 / auto. На gpt-oss проверены fp8 / fp8_e4m3.
KV_CACHE_DTYPE=fp8_e4m3

# Что: --gpu-memory-utilization.
# Для чего: пул VRAM под веса+KV; рецепт vLLM для H100/H200 — 0.92–0.95.
# Варианты: 0.95 — для max throughput при TP=1; 0.92 — TP=2 балансовый; снижать при OOM.
GPU_MEM_UTIL=0.92

# Что: --tensor-parallel-size.
# Для чего: рецепт vLLM `Balanced: TP=2, BS=128`. На H100/H200 TP=1 даёт max throughput per GPU,
#           TP=4/8 — min latency (BS=8). Для slgpu с автоподгоном TP под чекбоксы Inference оставляем TP=2.
# ВАЖНО: TP=2 + ENABLE_EXPERT_PARALLEL=1 — допустимо (gpt-oss MoE), но без EP всё ещё работает.
TP=2

# Что: 1 = vLLM --enable-expert-parallel (MoE с EP на нескольких GPU).
# Для чего: gpt-oss-120b — MoE (32 экспертов на слой), EP=1 даёт распределение экспертов по TP-shards.
# Варианты: 1 (рекомендуется при TP≥2). При TP=1 можно `0` — EP всё равно не задействуется.
ENABLE_EXPERT_PARALLEL=1

# Что: 1 = --trust-remote-code.
# Для чего: загрузка custom-классов токенизатора Harmony.
TRUST_REMOTE_CODE=1

# Что: --tool-call-parser.
# Для чего: парсер function-calls в Harmony-формате; добавлен в #22386 (vLLM 0.10.2+).
# Варианты: openai — единственный корректный для gpt-oss.
TOOL_CALL_PARSER=openai

# Что: --reasoning-parser.
# Для чего: разделение блока рассуждений (`<|channel|>analysis|>...`) на поле `reasoning_content`.
# Варианты: openai_gptoss — единственный корректный для gpt-oss-120b/20b.
REASONING_PARSER=openai_gptoss

# Что: 1 = --enable-auto-tool-choice.
# Для чего: без этого vLLM возвращает аргументы tool как plain content вместо `tool_calls[]` (#22337).
ENABLE_AUTO_TOOL_CHOICE=1

# Что: 1 = --enable-prefix-caching.
# Для чего: префикс-кэш улучшает throughput на повторяющихся системных промптах; gpt-oss совместим.
ENABLE_PREFIX_CACHING=1

# Что: 1 = --enable-chunked-prefill.
# Для чего: дефолт vLLM, баланс throughput/latency.
ENABLE_CHUNKED_PREFILL=1

# Что: vLLM --max-num-batched-tokens.
# Для чего: рецепт vLLM — 8192 (балансовая комбинация). При TP=1 + длинном контексте поднять GPU_MEM_UTIL и/или снизить.
# Варианты: 4096–16384.
MAX_NUM_BATCHED_TOKENS=8192

# Что: vLLM --max-num-seqs (BS).
# Для чего: «Balanced» рецепт — BS=128. Для max throughput TP=1 — увеличивать; для min latency TP=4/8 — снижать (8).
# Варианты: 8 / 32 / 64 / 128 / 256.
MAX_NUM_SEQS=128

# Что: SGLang --mem-fraction-static (если когда-то переключите слот на SGLang).
SGLANG_MEM_FRACTION_STATIC=0.90

# Что: маска GPU (под TP=2 по умолчанию). При выборе чекбоксами в UI Inference перезапишется (8.1.1).
NVIDIA_VISIBLE_DEVICES=0,1

# Что: поле model в бенче; пусто — взять из /v1/models.
BENCH_MODEL_NAME=
