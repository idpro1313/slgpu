# XiaomiMiMo/MiMo-V2.5 (310B / ~15B active) на 8×H200 через SGLang.
# Cookbook: https://docs.sglang.io/cookbook/autoregressive/Xiaomi/MiMo-V2.5
# Образ Hopper/CUDA 12.9 для non-Pro (`lmsysorg/sglang:latest` чекпоинт не грузит).
#
# Обязательны DP-attention: fused qkv в чекпоинте TP=4-interleaved; при одном только
# `--tp 8` без `--dp 2 --enable-dp-attention` возможна ошибка вида:
# MiMoV2 fused qkv_proj checkpoint is TP=4-interleaved; got attention tp_size=8.

# --- SGLang image (Hopper / CUDA 12.9 for MiMo-V2.5) ---
SGLANG_DOCKER_IMAGE=lmsysorg/sglang:dev-mimo-v2.5

# --- Identity ---
MODEL_ID=XiaomiMiMo/MiMo-V2.5
SERVED_MODEL_NAME=devllm
BENCH_MODEL_NAME=mimo-v2.5

# --- Required by web/backend PRESET_REQUIRED_KEYS (llm_env.py) ---
# Cookbook не задаёт контекст (в config до 1M); 262144 — практичный потолок KV на 8×H200.
MAX_MODEL_LEN=262144
TP=8
# Обязательно для валидации пресета; slgpu_run_sglang не читает (см. SGLANG_MEM_FRACTION_STATIC).
GPU_MEM_UTIL=0.95
NVIDIA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7

# --- SGLang (scripts/serve.sh) ---
SGLANG_TRUST_REMOTE_CODE=1
SGLANG_MEM_FRACTION_STATIC=0.65
KV_CACHE_DTYPE=fp8_e4m3
REASONING_PARSER=mimo
TOOL_CALL_PARSER=mimo

# --- DP-attention: TP=8, DP=2 (cookbook base|h200) ---
SGLANG_DP_SIZE=2
SGLANG_ENABLE_DP_ATTENTION=1
SGLANG_ENABLE_DP_LM_HEAD=1
SGLANG_MM_ENABLE_DP_ENCODER=1

# --- Chunked prefill ---
SGLANG_CHUNKED_PREFILL_SIZE=16384

# --- EAGLE MTP (cookbook default; на Hopper: SGLANG_ENABLE_SPEC_V2 + enable-multi-layer-eagle) ---
SGLANG_ENABLE_SPEC_V2=1
SGLANG_SPECULATIVE_ALGORITHM=EAGLE
SGLANG_SPECULATIVE_NUM_STEPS=3
SGLANG_SPECULATIVE_EAGLE_TOPK=1
SGLANG_SPECULATIVE_NUM_DRAFT_TOKENS=4
SGLANG_ENABLE_MULTI_LAYER_EAGLE=1
